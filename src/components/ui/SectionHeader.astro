---
interface Props {
  badge?: string;
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  light?: boolean; // true = teks putih (untuk dark section)
}

const {
  badge,
  title,
  subtitle,
  align = 'center',
  light = false
} = Astro.props;

const alignClass = align === 'center' ? 'text-center mx-auto' : 'text-left';
const titleColor = light ? 'text-[var(--color-text-inverse)]' : 'text-[var(--color-text-heading)]';
const subtitleColor = light ? 'text-[var(--color-text-muted)]' : 'text-[var(--color-text-body)]';
---

<div class={`max-w-3xl mb-12 animate-fade-in stagger-1 ${alignClass}`}>
  {badge && (
    <div class="inline-block px-3 py-1 mb-4 rounded-full bg-[var(--color-accent-dim)] text-[var(--color-accent)] text-sm font-semibold tracking-wide uppercase">
      {badge}
    </div>
  )}
  <h2 class={`font-display text-3xl md:text-4xl font-bold mb-4 ${titleColor}`}>
    {title}
  </h2>
  {subtitle && (
    <p class={`text-lg md:text-xl ${subtitleColor}`}>
      {subtitle}
    </p>
  )}
</div>
