---
interface Props {
  href: string;
  variant?: 'primary' | 'secondary';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = 'primary',
  class: className = '',
  target,
  rel,
} = Astro.props;

const base    = 'inline-flex items-center gap-2 px-6 py-3 rounded-full font-body font-semibold text-sm transition-all duration-150 focus-visible:outline-2 focus-visible:outline-offset-2';
const primary = 'bg-blue text-white hover:bg-blue/90 focus-visible:outline-blue';
const secondary = 'border border-white/40 text-white hover:border-white focus-visible:outline-white';

const classes = [base, variant === 'primary' ? primary : secondary, className].join(' ');
---

<a href={href} class={classes} target={target} rel={rel}>
  <slot />
</a>
