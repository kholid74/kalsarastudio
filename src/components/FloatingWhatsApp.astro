---
import { site } from '../config/site';
---

<a
  href={site.waUrl()}
  data-wa-location="floating_button"
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Hubungi Kalsara via WhatsApp"
  class="floating-wa group fixed bottom-5 right-5 z-50 inline-flex items-center gap-2.5 bg-[#25D366] text-white pl-3 pr-4 py-3 rounded-full shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-200"
>
  <span class="relative flex h-10 w-10 items-center justify-center rounded-full bg-white/15">
    <span class="absolute inline-flex h-full w-full rounded-full bg-white/30 opacity-75 animate-ping"></span>
    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 relative z-10" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
    </svg>
  </span>
  <span class="hidden sm:flex flex-col leading-tight pr-0.5">
    <span class="font-body font-semibold text-sm">Chat WhatsApp</span>
    <span class="font-body text-[11px] text-white/80">Balasan &lt; 1 jam</span>
  </span>
</a>

<style>
  /* Hide floating button on hero (so it doesn't compete with hero CTA on mobile) */
  @media (max-width: 640px) {
    .floating-wa {
      bottom: 1rem;
      right: 1rem;
    }
  }

  /* Respect users who prefer reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .floating-wa .animate-ping {
      animation: none;
    }
  }
</style>
