---
import SectionHeader from '../ui/SectionHeader.astro';
import { testimonials } from '../../data/testimonials';
import { Icon } from 'astro-icon/components';
---

<section id="testimonials" class="py-24 bg-[var(--color-surface)]">
  <div class="container mx-auto px-4 md:px-6">
    <SectionHeader
      badge="DARI KLIEN KAMI"
      title="Kata mereka yang sudah bekerja sama dengan kami."
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {testimonials.map((testi, i) => (
        <div class={`bg-white p-8 rounded-[var(--radius-xl)] shadow-[var(--shadow-sm)] border border-[var(--color-border)] flex flex-col animate-fade-in stagger-${i + 1}`}>
          
          <div class="flex items-center gap-1 mb-6">
            {Array.from({ length: testi.rating }).map(() => (
              <Icon name="lucide:star" class="w-5 h-5 fill-[#FBBF24] text-[#FBBF24]" />
            ))}
          </div>

          <blockquote class="flex-1 text-[var(--color-text-body)] italic leading-relaxed mb-8">
            "{testi.quote}"
          </blockquote>

          <div class="flex items-center gap-4 mt-auto pt-6 border-t border-[var(--color-border)]">
            <div class="avatar shrink-0">{testi.name.charAt(0)}</div>
            <div>
              <div class="font-display font-bold text-[var(--color-text-heading)]">{testi.name}</div>
              <div class="text-xs text-[var(--color-text-muted)]">{testi.business}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
