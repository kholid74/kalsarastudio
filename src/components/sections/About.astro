<section id="about" class="py-24 bg-[var(--color-surface-dark)] relative overflow-hidden">
  <div class="absolute right-0 top-0 w-1/2 h-full opacity-5 pointer-events-none" style="background-image: radial-gradient(var(--color-accent) 2px, transparent 2px); background-size: 32px 32px;"></div>

  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="max-w-2xl mx-auto text-center animate-fade-in stagger-1">
      <div class="inline-block px-3 py-1 mb-6 rounded-full bg-[var(--color-accent-dim)] text-[var(--color-accent)] text-sm font-semibold tracking-wide uppercase">
        TENTANG KALSARA
      </div>

      <h2 class="font-display text-3xl md:text-4xl font-bold mb-8 text-[var(--color-text-inverse)] leading-tight">
        Di Kalsara, kami percaya bahwa kehadiran digital yang baik bukan hak eksklusif bisnis besar.
      </h2>

      <p class="text-[var(--color-text-muted)] text-lg leading-relaxed">
        Kami hadir untuk membantu bisnis kamu tampil dengan cara yang mencerminkan kualitas sebenarnya.
      </p>
    </div>
  </div>
</section>
