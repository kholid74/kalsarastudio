---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';
---

<section class="bg-ink text-white py-20 md:py-28 px-6" id="tentang">
  <div class="max-w-site mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 items-center">

      <!-- Main content -->
      <div class="md:col-span-2">
        <SectionLabel dark class="mb-4">Tentang Kalsara</SectionLabel>

        <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white mb-6">
          Dibangun dengan Pengalaman,<br />Berfokus pada Solusi.
        </h2>

        <p class="font-body text-base text-white/60 leading-relaxed mb-8">
          Kalsara Digital Studio lahir dari pengalaman bertahun-tahun membangun solusi digital untuk berbagai kebutuhan bisnis. Kami percaya teknologi yang baik tidak harus rumit — yang penting tepat sasaran dan siap berkembang seiring bisnis Anda.
        </p>

        <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
          Mulai Konsultasi
        </Button>
      </div>

      <!-- Founder as supporting element -->
      <div class="md:col-span-1 flex flex-col items-center md:items-start">
        <div class="w-36 md:w-44 aspect-square rounded-full overflow-hidden bg-navy/50 border border-white/10 mb-4">
          <img
            src="/founder-placeholder.svg"
            alt="Kholid Putra — Founder Kalsara Digital Studio"
            class="w-full h-full object-cover"
            loading="lazy"
            width="200"
            height="200"
          />
        </div>
        <p class="font-heading font-bold text-base text-white">Kholid Putra</p>
        <p class="font-body text-sm text-white/50">Founder · Software Engineer</p>
        <p class="font-body text-xs text-white/30 mt-1">Berpengalaman sejak 2016</p>
      </div>
    </div>
  </div>
</section>
