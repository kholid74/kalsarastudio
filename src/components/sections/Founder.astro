---
import { Image } from 'astro:assets';
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';
import founderImg from '../../assets/founder.png';
---

<section class="bg-ink text-white py-20 md:py-28 px-6" id="tentang">
  <div class="max-w-site mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 items-center">

      <!-- Main content -->
      <div class="md:col-span-2">
        <SectionLabel dark class="mb-4">Tentang Kalsara</SectionLabel>

        <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white mb-6">
          Dibangun dengan Pengalaman,<br />Berfokus pada Solusi.
        </h2>

        <p class="font-body text-base text-white/60 leading-relaxed mb-8">
          Kalsara Digital Studio membantu bisnis membangun website dan solusi digital yang tidak hanya terlihat profesional, tetapi juga siap berkembang seiring kebutuhan bisnis.
        </p>

        <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer" data-wa-location="tentang_cta">
          Mulai Konsultasi
        </Button>
      </div>

      <!-- Founder as subtle supporting element -->
      <div class="md:col-span-1 flex flex-col items-center md:items-start">
        <div class="w-40 h-40 rounded-full overflow-hidden mb-3 shrink-0" style="border: 2px solid rgba(255,255,255,0.12);">
          <Image
            src={founderImg}
            alt="Kholid Putra — Founder Kalsara Digital Studio"
            width={160}
            height={160}
            format="webp"
            quality={85}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
        <p class="font-heading font-bold text-sm text-white">Kholid Putra</p>
        <p class="font-body text-xs text-white/50">Founder</p>
      </div>

    </div>
  </div>
</section>
