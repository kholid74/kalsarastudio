---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';
---

<section class="bg-ink text-white py-20 md:py-28 px-6" id="founder">
  <div class="max-w-site mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 items-center">

      <!-- Bio — takes 2/3 width on desktop -->
      <div class="md:col-span-2">
        <SectionLabel dark class="mb-4">Tentang Pendiri</SectionLabel>

        <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white mb-2">
          Halo, saya Kholid Putra.
        </h2>
        <p class="font-body text-sm text-cyan font-semibold tracking-wider uppercase mb-6">
          Software Engineer · 8+ Tahun Pengalaman
        </p>

        <div class="space-y-4 font-body text-base text-white/60 leading-relaxed mb-8">
          <p>
            Software Engineer dengan pengalaman lebih dari 8 tahun membangun dan mengembangkan sistem digital untuk berbagai kebutuhan bisnis, termasuk sistem skala enterprise di Indonesia.
          </p>
          <p>
            Melalui Kalsara Digital Studio, saya membantu bisnis memiliki website dan aplikasi yang dibangun dengan pendekatan engineering yang kuat — bukan sekadar tampilan yang menarik, tapi fondasi digital yang siap berkembang bersama bisnis Anda.
          </p>
        </div>

        <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
          Mulai Konsultasi
        </Button>
      </div>

      <!-- Portrait — takes 1/3 width on desktop -->
      <div class="md:col-span-1 flex flex-col items-center md:items-start">
        <div class="w-48 md:w-full max-w-xs aspect-[3/4] rounded-xl overflow-hidden bg-navy/50 border border-white/10">
          <img
            src="/founder-placeholder.svg"
            alt="Kholid Putra — Founder Kalsara Digital Studio"
            class="w-full h-full object-cover"
            loading="lazy"
            width="300"
            height="400"
          />
        </div>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="mt-14 pt-8 border-t border-white/10 flex flex-wrap gap-8 md:gap-16">
      <div>
        <p class="font-heading font-extrabold text-2xl text-white">8+</p>
        <p class="font-body text-xs text-white/40 uppercase tracking-widest mt-1">Tahun Pengalaman</p>
      </div>
      <div>
        <p class="font-heading font-extrabold text-2xl text-white">Enterprise</p>
        <p class="font-body text-xs text-white/40 uppercase tracking-widest mt-1">Scale Systems</p>
      </div>
      <div>
        <p class="font-heading font-extrabold text-2xl text-white">Engineering</p>
        <p class="font-body text-xs text-white/40 uppercase tracking-widest mt-1">First Approach</p>
      </div>
    </div>
  </div>
</section>
