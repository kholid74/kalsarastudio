---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';
---

<section class="bg-ink text-white py-20 md:py-28 px-6" id="tentang">
  <div class="max-w-site mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 md:gap-16 items-start">

      <!-- Main content — 2/3 width on desktop -->
      <div class="md:col-span-2">
        <SectionLabel dark class="mb-4">Tentang Kalsara</SectionLabel>

        <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white mb-6">
          Dibangun dengan Pengalaman,<br />Berfokus pada Solusi.
        </h2>

        <div class="space-y-4 font-body text-base text-white/60 leading-relaxed mb-8">
          <p>
            Kalsara Digital Studio lahir dari pengalaman bertahun-tahun di dunia pengembangan software dan solusi digital.
          </p>
          <p>
            Kami percaya bahwa teknologi yang baik tidak harus rumit. Karena itu, kami membantu bisnis membangun website dan solusi digital yang profesional, mudah digunakan, dan siap berkembang seiring pertumbuhan bisnis.
          </p>
        </div>

        <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
          Mulai Konsultasi
        </Button>
      </div>

      <!-- Founder as supporting element — 1/3 width on desktop -->
      <div class="md:col-span-1 flex flex-col items-center md:items-start">
        <div class="w-36 md:w-48 aspect-square rounded-full overflow-hidden bg-navy/50 border border-white/10 mb-4">
          <img
            src="/founder-placeholder.svg"
            alt="Kholid Putra — Founder Kalsara Digital Studio"
            class="w-full h-full object-cover"
            loading="lazy"
            width="200"
            height="200"
          />
        </div>
        <p class="font-heading font-bold text-base text-white">Kholid Putra</p>
        <p class="font-body text-sm text-white/50">Founder · Software Engineer</p>
      </div>
    </div>

    <!-- Stats strip -->
    <div class="mt-14 pt-8 border-t border-white/10 flex flex-wrap gap-8 md:gap-16">
      <div>
        <p class="font-heading font-extrabold text-2xl text-white">8+</p>
        <p class="font-body text-xs text-white/40 uppercase tracking-widest mt-1">Tahun Pengalaman</p>
      </div>
      <div>
        <p class="font-heading font-extrabold text-2xl text-white">Sejak 2016</p>
        <p class="font-body text-xs text-white/40 uppercase tracking-widest mt-1">Pengembangan Digital</p>
      </div>
      <div>
        <p class="font-heading font-extrabold text-2xl text-white">Bisnis Anda</p>
        <p class="font-body text-xs text-white/40 uppercase tracking-widest mt-1">Fokus Kami</p>
      </div>
    </div>
  </div>
</section>
