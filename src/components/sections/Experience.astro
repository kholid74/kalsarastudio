---
import { Image } from 'astro:assets';
import SectionLabel from '../ui/SectionLabel.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { site } from '../../config/site';
import { categories, projects } from '../../data/projects';

const statusClass = {
  'Client Project': 'text-blue bg-blue/8 border-blue/15',
  'Showcase Concept': 'text-amber-700 bg-amber-50 border-amber-200',
  'Coming Soon': 'text-muted bg-gray-50 border-border',
};
---

<section class="bg-surface py-20 md:py-28 px-6" id="karya">
  <div class="max-w-site mx-auto">

    <div class="mb-10">
      <SectionLabel class="mb-3">Karya Pilihan</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink">
        Yang Sudah Kami Bangun
      </h2>
      <p class="font-body text-base text-muted mt-4 max-w-xl leading-relaxed">
        Website dan showcase yang kami bangun untuk berbagai kebutuhan bisnis lokal — dari company profile, F&B, hingga klinik dan healthcare.
      </p>
    </div>

    <!-- Category filter tabs -->
    <div class="flex flex-wrap gap-2 mb-10" role="tablist" aria-label="Filter kategori portfolio">
      {categories.map((cat) => (
        <button
          data-filter={cat}
          role="tab"
          aria-selected={cat === 'Semua' ? 'true' : 'false'}
          class:list={[
            'portfolio-filter font-body text-sm font-medium px-4 py-2 rounded-full border transition-all',
            cat === 'Semua'
              ? 'bg-ink text-white border-ink'
              : 'bg-white text-muted border-border hover:border-ink/30 hover:text-ink',
          ]}
        >
          {cat}
        </button>
      ))}
    </div>

    <!-- Portfolio grid -->
    <div id="portfolio-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 mb-10">

      {projects.map((p, i) => (
        <article
          class="portfolio-card bg-white border border-border rounded-xl overflow-hidden flex flex-col group shadow-card hover:shadow-card-hover hover:-translate-y-1 transition-all duration-200"
          data-category={p.category}
          data-reveal
          data-reveal-delay={(i * 100).toString()}
        >
          <!-- Screenshot -->
          <div class="border-b border-border">
            <a href={`/karya/${p.slug}/`} class="block aspect-[16/10] bg-gray-100 overflow-hidden" aria-label={`Lihat detail ${p.title}`}>
              <Image
                src={p.image}
                alt={p.imageAlt}
                width={480}
                height={300}
                format="webp"
                quality={82}
                class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-300"
                loading="lazy"
              />
            </a>
          </div>

          <!-- Card content -->
          <div class="p-5 flex flex-col flex-1">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h3 class="font-heading font-bold text-base text-ink">{p.title}</h3>
              <div class="shrink-0 flex flex-col items-end gap-1">
                <span class:list={[
                  'font-body text-[10px] font-semibold uppercase tracking-wider border rounded-full px-2 py-0.5 whitespace-nowrap',
                  statusClass[p.status],
                ]}>
                  {p.status}
                </span>
                <span class="font-body text-xs font-medium text-blue bg-blue/8 border border-blue/15 rounded-full px-2.5 py-0.5 whitespace-nowrap">
                  {p.category}
                </span>
              </div>
            </div>
            <p class="font-body text-sm text-muted leading-relaxed mb-4 flex-1">{p.summary}</p>
            <div class="flex flex-wrap gap-1.5 mb-5">
              {p.tags.slice(0, 3).map((tag) => (
                <span class="font-body text-xs text-muted/70 border border-border rounded-full px-2.5 py-0.5">
                  {tag}
                </span>
              ))}
            </div>
            <div class="flex flex-wrap items-center gap-3">
              <a
                href={`/karya/${p.slug}/`}
                class="inline-flex items-center gap-1.5 font-body font-semibold text-sm text-blue hover:text-blue/80 transition-colors"
              >
                Lihat Detail
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <a
                href={p.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 font-body font-semibold text-sm text-muted hover:text-ink transition-colors"
              >
                Buka Website
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 7.5h9m0 0v9m0-9-9 9" />
                </svg>
              </a>
            </div>
          </div>
        </article>
      ))}

      <!-- Coming soon: E-Commerce -->
      <div
        class="portfolio-card bg-white border border-dashed border-border rounded-xl overflow-hidden flex flex-col"
        data-category="E-Commerce"
      >
        <div class="aspect-[16/10] bg-gray-50 flex items-center justify-center border-b border-dashed border-border">
          <span class="font-body text-xs text-muted/50 uppercase tracking-widest">Segera Hadir</span>
        </div>
        <div class="p-5 flex flex-col flex-1">
          <div class="flex items-start justify-between gap-2 mb-2">
            <h3 class="font-heading font-bold text-base text-ink/40">E-Commerce Project</h3>
            <span class="shrink-0 font-body text-xs font-medium text-muted border border-border rounded-full px-2.5 py-0.5 whitespace-nowrap">
              E-Commerce
            </span>
          </div>
          <p class="font-body text-sm text-muted/50 leading-relaxed">Toko online untuk bisnis produk lokal — sedang dalam pengerjaan.</p>
        </div>
      </div>

    </div>

    <!-- Empty state (shown when filter returns no results) -->
    <div id="portfolio-empty" class="hidden text-center py-12">
      <p class="font-body text-sm text-muted">Belum ada karya di kategori ini. Sedang dikerjakan.</p>
    </div>

    <WhatsAppButton
      href={site.waUrl()}
      location="karya_cta"
      class="inline-flex items-center gap-2 bg-ink text-white px-6 py-3 rounded-full font-body font-semibold text-sm hover:bg-ink/90 transition-colors"
    >
      Diskusikan Kebutuhan Anda
    </WhatsAppButton>

  </div>
</section>

<script>
  const filters = document.querySelectorAll<HTMLButtonElement>('.portfolio-filter');
  const cards   = document.querySelectorAll<HTMLElement>('.portfolio-card');
  const empty   = document.getElementById('portfolio-empty');

  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      const selected = btn.dataset.filter ?? 'Semua';

      // Update tab active state
      filters.forEach((f) => {
        const isActive = f.dataset.filter === selected;
        f.setAttribute('aria-selected', isActive ? 'true' : 'false');
        f.classList.toggle('bg-ink',    isActive);
        f.classList.toggle('text-white', isActive);
        f.classList.toggle('border-ink', isActive);
        f.classList.toggle('bg-white',  !isActive);
        f.classList.toggle('text-muted', !isActive);
        f.classList.toggle('border-border', !isActive);
      });

      // Show / hide cards
      let visible = 0;
      cards.forEach((card) => {
        const match = selected === 'Semua' || card.dataset.category === selected;
        card.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      empty?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
