---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';

const projects = [
  {
    title: 'Website Company Profile',
    desc: 'Website profesional untuk meningkatkan kredibilitas bisnis dan mempermudah pelanggan mendapatkan informasi.',
    tag: 'Concept Project',
  },
  {
    title: 'Landing Page Produk',
    desc: 'Fokus pada promosi produk dan peningkatan konversi — satu halaman, satu tujuan.',
    tag: 'Concept Project',
  },
  {
    title: 'Dashboard Internal',
    desc: 'Membantu pengelolaan data dan proses operasional bisnis dalam satu tampilan yang mudah digunakan.',
    tag: 'Sample Project',
  },
  {
    title: 'Sistem Booking',
    desc: 'Platform reservasi dan pengelolaan jadwal berbasis web untuk bisnis jasa dan layanan.',
    tag: 'Sample Project',
  },
] as const;
---

<section class="bg-surface py-20 md:py-28 px-6" id="karya">
  <div class="max-w-site mx-auto">
    <div class="mb-12">
      <SectionLabel class="mb-3">Karya Pilihan</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink">
        Contoh Website & Solusi Digital
      </h2>
      <p class="font-body text-base text-muted mt-4 max-w-xl leading-relaxed">
        Berbagai jenis website dan solusi digital yang kami kerjakan untuk membantu bisnis berkembang.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
      {projects.map((p) => (
        <div class="bg-white border border-border rounded-xl p-8 flex flex-col">
          <div class="flex items-start justify-between gap-4 mb-4">
            <h3 class="font-heading font-bold text-base text-ink">{p.title}</h3>
            <span class="shrink-0 font-body text-xs font-semibold text-muted border border-border rounded-full px-3 py-1 whitespace-nowrap">
              {p.tag}
            </span>
          </div>
          <p class="font-body text-sm text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>

    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
        Diskusikan Kebutuhan Anda
      </Button>
      <p class="font-body text-sm text-muted">
        Portofolio nyata sedang dikembangkan seiring pertumbuhan klien.
      </p>
    </div>
  </div>
</section>
