---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';

const projects = [
  {
    title: 'Garuda Pariwisata',
    category: 'Company Profile & Lead Generation Website',
    desc: 'Website company profile untuk bisnis tour & travel yang berfokus pada paket wisata Labuan Bajo. Dirancang untuk memudahkan calon pelanggan menemukan informasi paket perjalanan, melihat galeri destinasi, serta melakukan konsultasi dan reservasi langsung melalui WhatsApp.',
    tags: ['Company Profile', 'Travel & Tourism', 'WhatsApp Booking', 'SEO-Friendly', 'Mobile Responsive'],
    url: 'https://garudapariwisata.com',
    cta: 'Lihat Website',
    image: '/portfolio/garuda-pariwisata.svg',
    imageAlt: 'Screenshot website Garuda Pariwisata',
  },
  {
    title: 'Berkah Raya Farm',
    category: 'Product Landing Page & Business Website',
    desc: 'Landing page untuk produsen dan supplier telur asin yang bertujuan memperkenalkan produk, membangun kepercayaan calon pembeli, dan mempermudah proses pemesanan. Website menonjolkan kualitas produk, proses produksi, serta informasi bisnis secara profesional.',
    tags: ['Product Landing Page', 'Food Business', 'UMKM', 'WhatsApp Inquiry', 'Brand Trust Building'],
    url: 'https://berkah-raya-farm.vercel.app',
    cta: 'Lihat Website',
    image: '/portfolio/berkah-raya-farm.svg',
    imageAlt: 'Screenshot website Berkah Raya Farm',
  },
] as const;
---

<section class="bg-surface py-20 md:py-28 px-6" id="karya">
  <div class="max-w-site mx-auto">

    <div class="mb-14">
      <SectionLabel class="mb-3">Karya Pilihan</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink">
        Yang Sudah Kami Bangun
      </h2>
      <p class="font-body text-base text-muted mt-4 max-w-xl leading-relaxed">
        Beberapa website dan solusi digital yang kami bangun untuk membantu bisnis tampil lebih profesional dan berkembang secara digital.
      </p>
    </div>

    <!-- Alternating showcase -->
    <div class="space-y-16 md:space-y-24">
      {projects.map((p, i) => (
        <div class={`grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-14 items-center ${i % 2 === 1 ? 'md:[direction:rtl]' : ''}`}>

          <!-- Screenshot / mockup -->
          <div class={`${i % 2 === 1 ? 'md:[direction:ltr]' : ''}`}>
            <div class="rounded-2xl overflow-hidden border border-border shadow-lg bg-white">
              <!-- Browser chrome -->
              <div class="bg-gray-50 border-b border-border px-4 py-3 flex items-center gap-2">
                <div class="flex gap-1.5">
                  <div class="w-3 h-3 rounded-full bg-red-300"></div>
                  <div class="w-3 h-3 rounded-full bg-yellow-300"></div>
                  <div class="w-3 h-3 rounded-full bg-green-300"></div>
                </div>
                <div class="flex-1 bg-white border border-border rounded-md px-3 py-1 ml-2">
                  <p class="font-body text-xs text-muted truncate">{p.url.replace('https://', '')}</p>
                </div>
              </div>
              <!-- Screenshot area -->
              <div class="aspect-[16/10] bg-gray-100 overflow-hidden">
                <img
                  src={p.image}
                  alt={p.imageAlt}
                  class="w-full h-full object-cover object-top"
                  loading="lazy"
                  width="800"
                  height="500"
                />
              </div>
            </div>
          </div>

          <!-- Content -->
          <div class={`${i % 2 === 1 ? 'md:[direction:ltr]' : ''}`}>
            <p class="font-body text-xs font-semibold text-muted uppercase tracking-widest mb-3">{p.category}</p>
            <h3 class="font-heading font-extrabold text-2xl md:text-3xl text-ink mb-4">{p.title}</h3>
            <p class="font-body text-base text-muted leading-relaxed mb-6">{p.desc}</p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2 mb-8">
              {p.tags.map((tag) => (
                <span class="font-body text-xs font-medium text-ink/60 bg-white border border-border rounded-full px-3 py-1">
                  {tag}
                </span>
              ))}
            </div>

            <a
              href={p.url}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-body font-semibold text-sm text-blue hover:text-blue/80 transition-colors"
            >
              {p.cta}
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
              </svg>
            </a>
          </div>

        </div>
      ))}
    </div>

    <!-- Coming soon card -->
    <div class="mt-16 border border-dashed border-border rounded-2xl p-8 md:p-12 text-center">
      <p class="font-body text-xs font-semibold text-muted uppercase tracking-widest mb-3">Segera Hadir</p>
      <h3 class="font-heading font-bold text-xl text-ink mb-3">Custom Web Application</h3>
      <p class="font-body text-sm text-muted leading-relaxed max-w-md mx-auto">
        Contoh dashboard internal, sistem operasional, dan aplikasi web custom akan ditambahkan seiring bertambahnya project dan studi kasus.
      </p>
    </div>

    <div class="mt-12 flex flex-col sm:flex-row items-start sm:items-center gap-4">
      <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
        Diskusikan Kebutuhan Anda
      </Button>
    </div>

  </div>
</section>
