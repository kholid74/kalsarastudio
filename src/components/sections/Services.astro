---
import SectionHeader from '../ui/SectionHeader.astro';
import Button from '../ui/Button.astro';
import { services, addons } from '../../data/services';
import { Icon } from 'astro-icon/components';
---

<section id="services" class="py-24 bg-[var(--color-surface)]">
  <div class="container mx-auto px-4 md:px-6">
    <SectionHeader
      badge="LAYANAN KAMI"
      title="Setiap bisnis punya titik mulai yang berbeda."
      subtitle="Pilih yang paling sesuai kondisi sekarang — harga sudah termasuk semua yang kamu butuhkan."
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto mb-16 items-stretch">
      {services.map((pkg, index) => (
        <div class={`relative flex flex-col bg-white rounded-[var(--radius-xl)] shadow-[var(--shadow-sm)] border overflow-hidden animate-fade-in stagger-${index + 1} transition-all duration-300 hover:shadow-[var(--shadow-md)] hover:-translate-y-1 ${pkg.popular ? 'border-[var(--color-accent)] ring-1 ring-[var(--color-accent)]' : 'border-[var(--color-border)]'}`}>
          
          {pkg.popular && (
            <div class="bg-[var(--color-accent)] text-[var(--color-text-heading)] text-xs font-bold uppercase tracking-wider py-1.5 text-center">
              Paling Diminati
            </div>
          )}

          <div class="p-8 flex-1 flex flex-col">
            <h3 class="font-display text-2xl font-bold text-[var(--color-text-heading)] mb-2">{pkg.name}</h3>
            <div class="text-[var(--color-primary-light)] font-bold text-xl mb-4">{pkg.price}</div>
            
            <div class="text-sm text-[var(--color-text-body)] mb-6 space-y-1 pb-6 border-b border-[var(--color-border)]">
              <p><strong class="text-[var(--color-text-heading)]">Cocok untuk:</strong> {pkg.target}</p>
              <p><strong class="text-[var(--color-text-heading)]">Estimasi:</strong> {pkg.timeline}</p>
            </div>

            <p class="text-[var(--color-text-body)] text-sm leading-relaxed mb-8 flex-1">
              {pkg.description}
            </p>

            <Button href="#contact" variant={pkg.popular ? 'primary' : 'outline'} class="w-full mt-auto">
              Pilih {pkg.name}
            </Button>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
