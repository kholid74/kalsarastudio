---
import SectionLabel from '../ui/SectionLabel.astro';

const services = [
  {
    id:      'foundation',
    name:    'Website Company Profile & Landing Page',
    problem: 'Bisnis Anda belum punya website profesional, atau iklan digital Anda menghabiskan budget tanpa konversi yang jelas.',
    solution:'Kami bangun website atau landing page yang mencerminkan identitas bisnis Anda — bersih, cepat, rapi di HP, dan mudah ditemukan di Google.',
    price:   'Mulai Rp3.500.000',
    dark:    false,
  },
  {
    id:      'ecommerce',
    name:    'E-Commerce',
    problem: 'Anda bergantung pada marketplace pihak ketiga dan kehilangan kontrol atas data pelanggan.',
    solution:'Toko online mandiri dengan katalog produk, dashboard pesanan, pembayaran online, dan CMS yang bisa Anda kelola sendiri.',
    price:   'Mulai Rp7.500.000',
    dark:    false,
  },
  {
    id:      'custom-solution',
    name:    'Custom Solution',
    problem: 'Proses bisnis Anda manual dan tidak efisien karena tidak ada sistem yang sesuai.',
    solution:'Sistem digital yang dirancang khusus untuk proses bisnis Anda — booking klinik, portal pendaftaran sekolah, dashboard penjualan, CRM, atau automasi.',
    price:   'Mulai Rp15.000.000',
    dark:    true,
  },
] as const;
---

<section class="bg-white py-20 md:py-28 px-6" id="layanan">
  <div class="max-w-site mx-auto">
    <div class="mb-12" data-reveal>
      <SectionLabel class="mb-3">Layanan</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink">
        Dari Website hingga Aplikasi Custom.
      </h2>
    </div>

    <div class="services-grid grid grid-cols-1 md:grid-cols-3 gap-0 border border-border rounded-xl overflow-hidden shadow-card" data-reveal data-reveal-delay="100">
      {services.map((s) => (
        <div
          data-service={s.id}
          class={[
            'service-card relative flex flex-col p-7 border-b md:border-b-0 md:border-r border-border last:border-0',
            'border-t-4 transition-all duration-300',
            s.dark ? 'bg-navy border-t-cyan text-white' : 'bg-white border-t-blue text-ink hover:bg-surface',
          ].join(' ')}
        >
          <h3 class={`font-heading font-bold text-base mb-3 ${s.dark ? 'text-white' : 'text-ink'}`}>
            {s.name}
          </h3>
          <p class={`font-body text-sm leading-relaxed mb-3 ${s.dark ? 'text-white/50' : 'text-muted'}`}>
            {s.problem}
          </p>
          <p class={`font-body text-sm leading-relaxed mb-6 ${s.dark ? 'text-white/70' : 'text-ink/80'}`}>
            {s.solution}
          </p>
          <p class={`mt-auto font-body font-semibold text-sm ${s.dark ? 'text-cyan' : 'text-blue'}`}>
            {s.price}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  /* Service card hover: top-border thicken + subtle inner light */
  .service-card {
    isolation: isolate;
  }
  .service-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at top, rgba(30, 115, 255, 0.04), transparent 60%);
    opacity: 0;
    transition: opacity 300ms ease;
    pointer-events: none;
    z-index: 0;
  }
  .service-card:hover::before {
    opacity: 1;
  }
  .service-card > * {
    position: relative;
    z-index: 1;
  }
  .service-card.bg-navy::before {
    background: radial-gradient(circle at top, rgba(0, 212, 255, 0.08), transparent 60%);
  }
  .service-card.bg-navy:hover::before {
    opacity: 1;
  }
</style>
