---
import SectionLabel from '../ui/SectionLabel.astro';

const standards = [
  {
    title: 'Struktur Kode yang Rapi',
    desc: 'Kode ditulis dengan konvensi yang konsisten, mudah dibaca, dan mudah dirawat oleh developer mana pun di masa depan.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" />`,
  },
  {
    title: 'Performa Cepat',
    desc: 'Dioptimasi untuk loading cepat di semua perangkat dan koneksi — karena performa langsung mempengaruhi konversi bisnis.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />`,
  },
  {
    title: 'Siap Berkembang',
    desc: 'Arsitektur yang fleksibel sehingga fitur baru bisa ditambahkan tanpa harus merombak sistem dari awal.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />`,
  },
  {
    title: 'Dokumentasi Dasar',
    desc: 'Setiap proyek disertai dokumentasi yang cukup agar Anda memahami apa yang dibangun dan bagaimana mengelolanya.',
    icon: `<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />`,
  },
] as const;
---

<section class="bg-ink text-white py-20 md:py-28 px-6" id="standar">
  <div class="max-w-site mx-auto">
    <div class="mb-12">
      <SectionLabel dark class="mb-3">Standar Kami</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-white max-w-lg">
        Standar yang Kami Terapkan
      </h2>
      <p class="font-body text-base text-white/50 mt-4 max-w-xl leading-relaxed">
        Bukan sekadar klaim — ini adalah standar konkret yang kami terapkan di setiap proyek.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {standards.map((s) => (
        <div class="border border-white/10 rounded-xl p-7 hover:border-white/20 transition-colors">
          <div class="w-10 h-10 rounded-lg bg-white/5 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#22D3EE" class="w-5 h-5" set:html={s.icon} />
          </div>
          <h3 class="font-heading font-bold text-base text-white mb-2">{s.title}</h3>
          <p class="font-body text-sm text-white/50 leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
