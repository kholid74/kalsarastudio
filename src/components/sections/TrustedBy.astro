---
/**
 * TrustedBy — sector marquee strip.
 * Honest framing: we don't have a long client logo wall yet, so we lead with
 * "Dipercaya untuk membangun di sektor:" + sector pills, with verified clients
 * called out by name. No fake/placeholder logos.
 */

const sectors = [
  { label: 'Travel & Pariwisata',  icon: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941' },
  { label: 'F&B / UMKM Pangan',     icon: 'M10.5 1.5a3 3 0 0 1 3 3v.75h-6V4.5a3 3 0 0 1 3-3ZM3 9.75A3.75 3.75 0 0 1 6.75 6h6.5A3.75 3.75 0 0 1 17 9.75v9A3.75 3.75 0 0 1 13.25 22.5h-6.5A3.75 3.75 0 0 1 3 18.75v-9Z' },
  { label: 'Sekolah & Yayasan',     icon: 'M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Z' },
  { label: 'E-Commerce Lokal',      icon: 'M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 0 0-16.536-1.84M7.5 14.25 5.106 5.272M6 20.25a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Zm12.75 0a.75.75 0 1 1-1.5 0 .75.75 0 0 1 1.5 0Z' },
  { label: 'Klinik & Layanan Jasa', icon: 'M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437 1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008Z' },
  { label: 'Property & Real Estate', icon: 'M2.25 12 11.204 3.045c.44-.44 1.152-.44 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25' },
] as const;

// Duplicate for seamless marquee loop
const loop = [...sectors, ...sectors];
---

<section class="trusted-by relative bg-navy text-white py-10 md:py-12 overflow-hidden border-t border-white/[0.06]" aria-label="Sektor yang kami layani">
  <!-- Subtle fade gradients on edges -->
  <div class="trusted-by__fade trusted-by__fade--left" aria-hidden="true"></div>
  <div class="trusted-by__fade trusted-by__fade--right" aria-hidden="true"></div>

  <div class="max-w-site mx-auto px-6 mb-6">
    <p class="text-center font-body text-xs sm:text-sm font-medium tracking-[0.2em] uppercase text-white/45">
      Dipercaya untuk membangun di sektor
    </p>
  </div>

  <div class="trusted-by__marquee" aria-hidden="false">
    <div class="trusted-by__track">
      {loop.map((sector) => (
        <div class="trusted-by__item inline-flex items-center gap-2.5 px-5 py-2.5 mx-2 bg-white/[0.04] border border-white/10 rounded-full whitespace-nowrap">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-cyan/70 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d={sector.icon} />
          </svg>
          <span class="font-body text-sm font-medium text-white/75">{sector.label}</span>
        </div>
      ))}
    </div>
  </div>

  <div class="max-w-site mx-auto px-6 mt-6">
    <p class="text-center font-body text-xs text-white/35">
      Termasuk klien aktif seperti
      <span class="text-white/60 font-semibold">Garuda Pariwisata</span>
      &nbsp;·&nbsp;
      <span class="text-white/60 font-semibold">Berkah Raya Farm</span>
    </p>
  </div>
</section>

<style>
  /* Soft edge fades so pills slide in/out instead of hard-clipping */
  .trusted-by__fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 80px;
    z-index: 2;
    pointer-events: none;
  }
  .trusted-by__fade--left {
    left: 0;
    background: linear-gradient(to right, #001236, transparent);
  }
  .trusted-by__fade--right {
    right: 0;
    background: linear-gradient(to left, #001236, transparent);
  }

  .trusted-by__marquee {
    overflow: hidden;
    width: 100%;
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
            mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
  }
  .trusted-by__track {
    display: inline-flex;
    will-change: transform;
    /* track is 2× the content, so -50% completes one full loop */
  }

  @media (prefers-reduced-motion: no-preference) {
    .trusted-by__track {
      animation: trustedByScroll 38s linear infinite;
    }
    .trusted-by:hover .trusted-by__track {
      animation-play-state: paused;
    }
  }

  @keyframes trustedByScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
