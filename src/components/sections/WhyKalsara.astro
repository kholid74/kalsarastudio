---
import SectionLabel from '../ui/SectionLabel.astro';

const points = [
  {
    title: 'Solusi yang Disesuaikan',
    desc:  'Setiap bisnis punya kebutuhan yang berbeda. Kami tidak menawarkan paket template — kami mendengarkan kebutuhan Anda dan membangun solusi yang tepat.',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />`,
  },
  {
    title: 'Komunikasi yang Jelas',
    desc:  'Tidak ada istilah teknis yang membingungkan. Anda selalu tahu perkembangan proyek dan bisa berkomunikasi langsung dengan tim yang mengerjakan.',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H8.25m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0H12m4.125 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm0 0h-.375m-13.5 3.01c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.184-4.183a1.14 1.14 0 0 1 .778-.332 48.294 48.294 0 0 0 5.83-.498c1.585-.233 2.708-1.626 2.708-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />`,
  },
  {
    title: 'Fokus pada Kebutuhan Bisnis',
    desc:  'Website dan solusi digital yang kami bangun dirancang untuk mendukung tujuan bisnis Anda — bukan sekadar terlihat bagus di portofolio kami.',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />`,
  },
  {
    title: 'Siap Berkembang',
    desc:  'Solusi yang kami bangun hari ini dirancang agar bisa berkembang seiring bisnis Anda — tanpa perlu memulai dari nol setiap kali ada kebutuhan baru.',
    icon:  `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />`,
  },
] as const;
---

<section class="bg-surface py-20 md:py-28 px-6" id="mengapa">
  <div class="max-w-site mx-auto">
    <div class="mb-12">
      <SectionLabel class="mb-3">Mengapa Kalsara</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink max-w-lg">
        Mitra Digital yang Berfokus pada Pertumbuhan Bisnis Anda.
      </h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {points.map((p) => (
        <div data-point class="bg-white border border-border rounded-xl p-7">
          <div class="w-10 h-10 rounded-lg bg-blue/10 flex items-center justify-center mb-5">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="#1E73FF" class="w-5 h-5" set:html={p.icon} />
          </div>
          <h3 class="font-heading font-bold text-base text-ink mb-2">{p.title}</h3>
          <p class="font-body text-sm text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
