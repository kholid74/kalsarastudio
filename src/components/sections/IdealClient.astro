---
import SectionLabel from '../ui/SectionLabel.astro';
import Button from '../ui/Button.astro';
import { site } from '../../config/site';

const criteria = [
  'Baru ingin memiliki website profesional untuk bisnisnya',
  'Ingin menjual produk secara online dengan toko sendiri',
  'Masih menggunakan proses manual yang memakan waktu',
  'Membutuhkan sistem yang bisa berkembang seiring bisnis',
  'Mencari partner digital jangka panjang, bukan vendor satu kali',
] as const;
---

<section class="bg-white py-20 md:py-28 px-6" id="cocok-untuk">
  <div class="max-w-site mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16 items-center">

      <div>
        <SectionLabel class="mb-4">Untuk Siapa</SectionLabel>
        <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink mb-4">
          Kalsara Cocok untuk<br />Bisnis yang&hellip;
        </h2>
        <p class="font-body text-base text-muted leading-relaxed">
          Kami membantu bisnis dari berbagai tahap — dari yang baru mulai hingga yang siap berkembang lebih jauh.
        </p>
      </div>

      <div class="space-y-3">
        {criteria.map((item) => (
          <div class="flex items-start gap-3">
            <div class="w-5 h-5 rounded-full bg-blue/10 flex items-center justify-center shrink-0 mt-0.5">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
              </svg>
            </div>
            <p class="font-body text-base text-ink leading-relaxed">{item}</p>
          </div>
        ))}

        <div class="pt-4">
          <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
            Ini untuk Saya — Mulai Konsultasi
          </Button>
        </div>
      </div>

    </div>
  </div>
</section>
