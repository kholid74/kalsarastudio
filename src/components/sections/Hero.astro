---
import { Image } from 'astro:assets';
import { site } from '../../config/site';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
import imgGaruda from '../../assets/portfolio/project_garuda.png';
import imgBerkah from '../../assets/portfolio/project_berkah_raya.png';
---

<section class="hero relative overflow-hidden bg-navy text-white py-24 md:py-32 lg:py-36 px-6 isolate" id="hero">
  <!-- Decorative background layers -->
  <div class="hero__bg-grid" aria-hidden="true"></div>
  <div class="hero__bg-glow hero__bg-glow--top-left" aria-hidden="true"></div>
  <div class="hero__bg-glow hero__bg-glow--bottom-right" aria-hidden="true"></div>
  <div class="hero__bg-gradient" aria-hidden="true"></div>

  <div class="relative max-w-site mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-10 items-center">

      <!-- Left: text column -->
      <div class="lg:col-span-7 text-center lg:text-left">
        <Badge class="mb-8">Digital Studio · Indonesia</Badge>

        <h1 class="hero__heading font-heading font-extrabold text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] xl:text-[5rem] leading-[1.05] tracking-tight mb-6">
          Bukan Sekadar Website.<br />
          <span class="text-cyan">Fondasi Digital</span> untuk Bisnis Anda.
        </h1>

        <p class="font-body text-lg md:text-xl text-white/70 leading-relaxed mb-10 max-w-xl mx-auto lg:mx-0">
          Untuk UMKM, sekolah, dan bisnis lokal yang siap naik kelas — dari company profile pertama sampai sistem custom yang tumbuh bersama bisnis Anda.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer" variant="primary" data-wa-location="hero_cta">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Konsultasi Gratis via WhatsApp
          </Button>

          <Button href="#layanan" variant="secondary">
            Lihat Layanan
          </Button>
        </div>

        <div class="mt-8 flex flex-wrap items-center justify-center lg:justify-start gap-x-5 gap-y-2 font-body text-xs sm:text-sm text-white/50">
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-cyan" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
            </svg>
            8+ tahun pengalaman engineering
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-cyan" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
            </svg>
            Maksimal 4 proyek per bulan
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-cyan" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
            </svg>
            Anda dapat source code-nya
          </span>
        </div>

        <!-- Value progression visual -->
        <div class="mt-10 flex items-center justify-center lg:justify-start gap-1 sm:gap-2 flex-wrap">
          <div class="flex items-center gap-1 sm:gap-2">
            <span class="font-body text-xs sm:text-sm font-medium text-white bg-white/8 border border-white/10 px-3 py-1.5 rounded-lg">
              Website
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white/20 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
          <div class="flex items-center gap-1 sm:gap-2">
            <span class="font-body text-xs sm:text-sm font-medium text-white/70 bg-white/5 border border-white/8 px-3 py-1.5 rounded-lg">
              E-Commerce
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white/20 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
          <div class="flex items-center gap-1 sm:gap-2">
            <span class="font-body text-xs sm:text-sm font-medium text-white/60 bg-white/5 border border-white/8 px-3 py-1.5 rounded-lg">
              Dashboard
            </span>
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white/20 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </div>
          <span class="font-body text-xs sm:text-sm font-semibold text-cyan bg-cyan/10 border border-cyan/30 px-3 py-1.5 rounded-lg">
            Custom System
          </span>
        </div>
        <p class="mt-3 font-body text-xs text-white/25 text-center lg:text-left">Mulai dari kebutuhan sederhana, berkembang sesuai bisnis Anda.</p>
      </div>

      <!-- Right: browser mockup (hidden on mobile/tablet, shown lg+) -->
      <div class="hero__mockup hidden lg:block lg:col-span-5 relative">
        <div class="hero__mockup-glow" aria-hidden="true"></div>

        <!-- Main browser window (foreground) -->
        <div class="hero__browser hero__browser--front relative bg-white/[0.04] backdrop-blur-sm border border-white/15 rounded-xl overflow-hidden shadow-[0_30px_80px_-20px_rgba(0,0,0,0.55),0_0_0_1px_rgba(255,255,255,0.06)_inset]">
          <!-- Browser chrome -->
          <div class="bg-white/[0.06] px-3 py-2.5 flex items-center gap-1.5 border-b border-white/10">
            <div class="w-2.5 h-2.5 rounded-full bg-red-400/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-yellow-400/60"></div>
            <div class="w-2.5 h-2.5 rounded-full bg-green-400/60"></div>
            <div class="ml-3 flex-1 bg-white/[0.06] border border-white/10 rounded px-2.5 py-1 max-w-[260px]">
              <p class="font-body text-[10px] text-white/50 truncate">garudapariwisata.com</p>
            </div>
          </div>
          <Image
            src={imgGaruda}
            alt="Contoh website Kalsara — Garuda Pariwisata"
            width={760}
            height={475}
            format="webp"
            quality={88}
            class="w-full h-auto block"
            loading="eager"
          />
        </div>

        <!-- Secondary mini browser (background, offset bottom-left) -->
        <div class="hero__browser hero__browser--back absolute -bottom-8 -left-10 w-[58%] bg-white/[0.03] backdrop-blur-sm border border-white/10 rounded-lg overflow-hidden shadow-[0_20px_50px_-10px_rgba(0,0,0,0.5)] hidden xl:block">
          <div class="bg-white/[0.05] px-2 py-1.5 flex items-center gap-1 border-b border-white/10">
            <div class="w-1.5 h-1.5 rounded-full bg-red-400/50"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-yellow-400/50"></div>
            <div class="w-1.5 h-1.5 rounded-full bg-green-400/50"></div>
          </div>
          <Image
            src={imgBerkah}
            alt="Contoh website Kalsara — Berkah Raya Farm"
            width={420}
            height={263}
            format="webp"
            quality={82}
            class="w-full h-auto block"
            loading="eager"
          />
        </div>

        <!-- Floating stat badge (top-right of mockup) -->
        <div class="hero__stat-badge absolute -top-4 -right-4 xl:-right-6 bg-white/[0.08] backdrop-blur-md border border-white/15 rounded-xl px-4 py-3 shadow-[0_10px_30px_rgba(0,0,0,0.3)]">
          <div class="flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-cyan/30 to-blue/30 ring-1 ring-cyan/40 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-cyan" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
              </svg>
            </div>
            <div>
              <p class="font-heading font-bold text-base text-white leading-tight">+50%</p>
              <p class="font-body text-[10px] text-white/55 leading-tight whitespace-nowrap">inquiry naik</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Hero decorative background layers */
  .hero {
    background:
      radial-gradient(ellipse 80% 50% at 50% -20%, rgba(0, 212, 255, 0.15), transparent 70%),
      linear-gradient(180deg, #001F54 0%, #001A47 50%, #001236 100%);
  }

  /* Grid pattern overlay */
  .hero__bg-grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(to right, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 40%, black 30%, transparent 80%);
    z-index: 0;
    pointer-events: none;
  }

  /* Soft glow orbs — adds depth without overwhelming */
  .hero__bg-glow {
    position: absolute;
    border-radius: 9999px;
    filter: blur(80px);
    opacity: 0.5;
    z-index: 0;
    pointer-events: none;
    will-change: transform;
  }
  .hero__bg-glow--top-left {
    width: 480px;
    height: 480px;
    top: -120px;
    left: -160px;
    background: radial-gradient(circle, rgba(30, 115, 255, 0.35), transparent 60%);
  }
  .hero__bg-glow--bottom-right {
    width: 560px;
    height: 560px;
    bottom: -200px;
    right: -180px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.18), transparent 60%);
  }

  /* Bottom gradient fade for smooth section transition */
  .hero__bg-gradient {
    position: absolute;
    inset: auto 0 0 0;
    height: 120px;
    background: linear-gradient(180deg, transparent, rgba(0, 18, 54, 0.6));
    z-index: 0;
    pointer-events: none;
  }

  /* Subtle ambient drift on glow orbs */
  @media (prefers-reduced-motion: no-preference) {
    .hero__bg-glow--top-left {
      animation: heroGlowDrift1 18s ease-in-out infinite;
    }
    .hero__bg-glow--bottom-right {
      animation: heroGlowDrift2 22s ease-in-out infinite;
    }
  }

  @keyframes heroGlowDrift1 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(40px, 30px) scale(1.05); }
  }
  @keyframes heroGlowDrift2 {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, -40px) scale(1.08); }
  }

  /* Headline gradient on the highlight word */
  .hero__heading .text-cyan {
    background: linear-gradient(135deg, #00D4FF 0%, #5EEAFF 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  /* Mockup wrapper — soft glow halo behind */
  .hero__mockup {
    perspective: 1200px;
  }
  .hero__mockup-glow {
    position: absolute;
    inset: -40px;
    background: radial-gradient(ellipse 70% 60% at 50% 50%, rgba(0, 212, 255, 0.18), transparent 70%);
    filter: blur(40px);
    z-index: -1;
    pointer-events: none;
  }

  /* Front browser tilt + float */
  .hero__browser--front {
    transform: perspective(1200px) rotateY(-4deg) rotateX(2deg);
    transform-origin: center center;
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero__browser--front {
      animation: heroMockupFloat 8s ease-in-out infinite;
    }
    .hero__stat-badge {
      animation: heroStatFloat 6s ease-in-out infinite;
    }
  }
  @keyframes heroMockupFloat {
    0%, 100% { transform: perspective(1200px) rotateY(-4deg) rotateX(2deg) translateY(0); }
    50% { transform: perspective(1200px) rotateY(-4deg) rotateX(2deg) translateY(-8px); }
  }
  @keyframes heroStatFloat {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
</style>

