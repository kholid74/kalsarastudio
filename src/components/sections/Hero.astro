---
import { site } from '../../config/site';
import Badge from '../ui/Badge.astro';
import Button from '../ui/Button.astro';
---

<section class="bg-navy text-white py-28 md:py-36 px-6" id="hero">
  <div class="max-w-content mx-auto text-center">
    <Badge class="mb-8">Software Engineering Studio</Badge>

    <h1 class="font-heading font-extrabold text-4xl md:text-5xl lg:text-6xl leading-tight mb-6">
      Bukan Sekadar Website.<br />
      <span class="text-cyan">Fondasi Digital</span> untuk Bisnis Anda.
    </h1>

    <p class="font-body text-lg text-white/60 leading-relaxed mb-10 max-w-xl mx-auto">
      Dari company profile hingga aplikasi custom, Kalsara membantu bisnis membangun fondasi digital dengan standar engineering yang kuat.
    </p>

    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer" variant="primary">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
        </svg>
        Konsultasi Gratis via WhatsApp
      </Button>

      <Button href="#layanan" variant="secondary">
        Lihat Layanan
      </Button>
    </div>

    <p class="mt-6 font-body text-sm text-white/40">
      Dibangun oleh Software Engineer dengan pengalaman 8+ tahun.
    </p>
  </div>
</section>
