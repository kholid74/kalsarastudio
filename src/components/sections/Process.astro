---
import SectionHeader from '../ui/SectionHeader.astro';
import { process } from '../../data/process';

export function titleFormat(title: string) {
  if (title.includes('🎉')) {
    return title.replace('🎉', '<span class="inline-block hover:scale-125 transition-transform cursor-default">🎉</span>');
  }
  return title;
}
---

<section id="process" class="py-24 bg-[var(--color-bg)]">
  <div class="container mx-auto px-4 md:px-6">
    <SectionHeader
      badge="CARA KERJA"
      title="Proses yang jelas dari awal."
      subtitle="Tidak ada kejutan di tengah jalan."
    />

    <div class="max-w-6xl mx-auto relative mt-16 animate-fade-in stagger-2">
      <!-- Horizontal line for desktop -->
      <div class="hidden md:block absolute top-[2.5rem] left-[5%] right-[5%] h-0.5 bg-[var(--color-border)] z-0"></div>
      
      <div class="grid grid-cols-1 md:grid-cols-6 gap-8 relative z-10">
        {process.map((step, i) => (
          <div class="flex flex-row md:flex-col items-start md:items-center gap-6 md:gap-4 group">
            
            <!-- Mobile vertical line connection (except last) -->
            <div class="md:hidden flex flex-col items-center">
              <div class="w-12 h-12 rounded-full bg-white border-2 border-[var(--color-border)] flex items-center justify-center font-display font-bold text-[var(--color-primary-light)] group-hover:border-[var(--color-primary-light)] transition-colors z-10 shadow-sm shrink-0">
                {step.no}
              </div>
              {i !== process.length - 1 && (
                <div class="w-0.5 h-full min-h-[40px] bg-[var(--color-border)] -mb-6 mt-2"></div>
              )}
            </div>

            <!-- Desktop circle -->
            <div class="hidden md:flex w-20 h-20 rounded-full bg-white border-2 border-[var(--color-border)] items-center justify-center font-display text-xl font-bold text-[var(--color-primary-light)] group-hover:border-[var(--color-primary-light)] transition-colors shadow-[var(--shadow-sm)] shrink-0 mx-auto">
              {step.no}
            </div>

            <!-- Content -->
            <div class="md:text-center pt-2 md:pt-0 flex-1">
              <div class="inline-block px-2 py-1 mb-2 md:mb-3 rounded text-[0.65rem] font-bold tracking-wider uppercase bg-[var(--color-surface)] text-[var(--color-text-muted)]">
                {step.time}
              </div>
              <h3 class="font-display font-bold text-[var(--color-text-heading)] mb-2 md:text-sm lg:text-base leading-tight" set:html={titleFormat(step.title)}></h3>
              <p class="text-sm text-[var(--color-text-body)]">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
