---
import Button from '../ui/Button.astro';
import { Icon } from 'astro-icon/components';
---

<section id="contact" class="py-24 relative overflow-hidden bg-gradient-to-br from-[var(--color-surface-dark)] to-[#071426]">
  <!-- Glow effects -->
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-3xl h-64 bg-[var(--color-accent)]/10 blur-[100px] pointer-events-none rounded-full"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-[var(--color-primary-light)]/20 blur-[120px] pointer-events-none rounded-full"></div>

  <div class="container mx-auto px-4 md:px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">

      <div class="inline-block px-3 py-1 mb-6 rounded-full bg-[var(--color-accent-dim)] text-[var(--color-accent)] text-sm font-semibold tracking-wide uppercase animate-fade-in stagger-1">
        MULAI SEKARANG
      </div>

      <h2 class="font-display text-4xl md:text-5xl font-bold text-white mb-6 animate-fade-in stagger-2">
        Mari ngobrol dulu.
      </h2>
      
      <p class="text-lg text-[#94A3B8] max-w-2xl mx-auto mb-10 leading-relaxed animate-fade-in stagger-3">
        Ceritakan bisnis kamu — tantangan, goals, atau sekadar ide awal yang masih samar. Kami bantu pikirkan langkah yang paling masuk akal.
        <br/><br/>
        Biasanya kami balas dalam 2 jam di jam kerja (09.00–18.00 WIB).
      </p>

      <div class="animate-fade-in stagger-4 mb-6">
        <Button 
          href="https://wa.me/6285156589720?text=Halo+Kalsara,+saya+ingin+konsultasi+soal+website+untuk+bisnis+saya."
          variant="primary" 
          size="lg" 
          class="w-full sm:w-auto shadow-lg shadow-[var(--color-accent)]/20"
        >
          <Icon name="lucide:message-circle" class="w-5 h-5 mr-2" />
          Hubungi via WhatsApp &rarr;
        </Button>
      </div>

      <p class="text-[var(--color-text-muted)] text-sm mb-16 animate-fade-in stagger-4">
        Atau email kami: <a href="mailto:hello@kalsara.id" class="text-[var(--color-accent)] hover:underline">hello@kalsara.id</a>
      </p>

      <!-- Trust signals -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 pt-10 border-t border-[var(--color-border-dark)] animate-fade-in stagger-5">
        <div class="flex items-center justify-center md:justify-start gap-3 text-left">
          <div class="w-10 h-10 rounded-full bg-[var(--color-primary)] flex items-center justify-center shrink-0 border border-[var(--color-border-dark)]">
            <Icon name="lucide:clipboard-list" class="w-4 h-4 text-[var(--color-accent)]" />
          </div>
          <span class="text-sm font-medium text-white">Konsultasi gratis, tidak ada kewajiban</span>
        </div>
        
        <div class="flex items-center justify-center gap-3 text-left">
          <div class="w-10 h-10 rounded-full bg-[var(--color-primary)] flex items-center justify-center shrink-0 border border-[var(--color-border-dark)]">
            <Icon name="lucide:lock" class="w-4 h-4 text-[var(--color-accent)]" />
          </div>
          <span class="text-sm font-medium text-white">Harga terkunci di proposal</span>
        </div>
        
        <div class="flex items-center justify-center md:justify-end gap-3 text-left">
          <div class="w-10 h-10 rounded-full bg-[var(--color-primary)] flex items-center justify-center shrink-0 border border-[var(--color-border-dark)]">
            <Icon name="lucide:users" class="w-4 h-4 text-[var(--color-accent)]" />
          </div>
          <span class="text-sm font-medium text-white">Kami masih ada setelah proyek selesai</span>
        </div>
      </div>

    </div>
  </div>
</section>
