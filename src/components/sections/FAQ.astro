---
import SectionLabel from '../ui/SectionLabel.astro';

type Category = 'proses' | 'harga' | 'teknis';

const categories: Record<Category, { label: string; icon: string; color: string }> = {
  proses: {
    label: 'Proses & Timeline',
    icon: 'M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z',
    color: 'cyan',
  },
  harga: {
    label: 'Harga & Pembayaran',
    icon: 'M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm3 0h.008v.008H18V10.5Zm-12 0h.008v.008H6V10.5Z',
    color: 'blue',
  },
  teknis: {
    label: 'Teknis & Kepemilikan',
    icon: 'M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5',
    color: 'cyan',
  },
};

const faqs: Array<{ q: string; a: string; cat: Category }> = [
  {
    cat: 'proses',
    q: 'Berapa lama proses pengerjaan website?',
    a: 'Foundation (company profile & landing page) biasanya selesai dalam 7–14 hari kerja. Growth (e-commerce) 14–21 hari kerja. Custom Solution 30–60 hari kerja, tergantung kompleksitas. Timeline detail akan kami sampaikan dalam proposal setelah scope disepakati.',
  },
  {
    cat: 'proses',
    q: 'Berapa kali revisi yang diperbolehkan?',
    a: 'Setiap paket mencakup 2 kali revisi desain sebelum development dimulai. Setelah website live, revisi konten minor (teks, gambar, informasi) dapat dilakukan selama masa support tanpa biaya tambahan. Perubahan struktur, fitur baru, atau halaman tambahan di luar scope awal akan kami sampaikan estimasi biayanya secara transparan sebelum dikerjakan.',
  },
  {
    cat: 'harga',
    q: 'Apakah domain dan hosting sudah termasuk dalam harga?',
    a: 'Tidak termasuk. Kami akan membantu merekomendasikan penyedia hosting yang sesuai dengan kebutuhan Anda dan memandu proses setup-nya. Biaya domain biasanya Rp100.000–200.000/tahun dan hosting mulai dari Rp50.000/bulan, tergantung penyedia dan spesifikasi.',
  },
  {
    cat: 'harga',
    q: 'Apakah termasuk copywriting dan foto produk?',
    a: 'Tidak termasuk. Kami fokus pada pembangunan website: desain, struktur, dan sistem. Untuk copywriting dan fotografi produk, Anda bisa menyiapkan sendiri dengan panduan format dari kami.',
  },
  {
    cat: 'harga',
    q: 'Saya sudah punya domain. Apakah bisa dipakai untuk website dari Kalsara?',
    a: 'Bisa. Jika Anda sudah memiliki domain, kami akan membantu menghubungkannya ke hosting baru tanpa kehilangan email atau konfigurasi yang sudah ada. Tidak ada biaya tambahan untuk ini.',
  },
  {
    cat: 'teknis',
    q: 'Siapa yang memiliki source code dan konten website?',
    a: 'Anda. Setelah pelunasan, seluruh source code, aset desain, dan konten website menjadi hak milik Anda sepenuhnya. Tidak ada biaya lisensi atau ketergantungan pada kami. Kalau suatu saat Anda ingin pindah atau dikelola developer lain, kami akan bantu serah-terima dengan rapi.',
  },
  {
    cat: 'teknis',
    q: 'Bisakah website ini dikembangkan menjadi sistem yang lebih besar?',
    a: 'Bisa. Inilah salah satu keunggulan Kalsara. Website Anda dibangun dengan arsitektur yang dapat berkembang — dari company profile ke dashboard penjualan, dari landing page ke sistem booking, atau dari website sekolah ke portal pendaftaran online. Anda tidak perlu membangun ulang dari nol saat bisnis berkembang.',
  },
];

// Group by category for rendering, preserving category order
const groupOrder: Category[] = ['proses', 'harga', 'teknis'];
const grouped = groupOrder.map((cat) => ({
  cat,
  meta: categories[cat],
  items: faqs.filter((f) => f.cat === cat),
})).filter((g) => g.items.length > 0);
---

<section class="bg-surface py-20 md:py-28 px-6" id="faq">
  <div class="max-w-content mx-auto">
    <div class="mb-12 text-center" data-reveal>
      <SectionLabel class="mb-3 justify-center">Pertanyaan Umum</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink">
        Pertanyaan yang Sering Ditanyakan.
      </h2>
      <p class="font-body text-base text-muted mt-4 max-w-xl mx-auto">
        Jawaban jujur untuk hal-hal yang paling sering ditanyakan calon klien sebelum mulai proyek.
      </p>
    </div>

    {grouped.map((group, gi) => (
      <div class="faq-group mb-8 last:mb-0" data-reveal data-reveal-delay={(gi * 100).toString()}>
        <!-- Category header -->
        <div class="flex items-center gap-3 mb-4">
          <div class={[
            'w-9 h-9 rounded-lg flex items-center justify-center ring-1',
            group.meta.color === 'cyan'
              ? 'bg-gradient-to-br from-cyan/15 to-blue/15 ring-cyan/30'
              : 'bg-gradient-to-br from-blue/10 to-cyan/10 ring-blue/25',
          ].join(' ')}>
            <svg xmlns="http://www.w3.org/2000/svg" class={`w-5 h-5 ${group.meta.color === 'cyan' ? 'text-cyan' : 'text-blue'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={group.meta.icon} />
            </svg>
          </div>
          <h3 class="font-heading font-bold text-base text-ink tracking-tight">
            {group.meta.label}
          </h3>
          <span class="font-body text-xs text-muted/60">({group.items.length})</span>
        </div>

        <!-- Items -->
        <div class="space-y-3">
          {group.items.map((faq) => (
            <details class="faq-item group bg-white border border-border rounded-xl overflow-hidden transition-all duration-200 hover:border-blue/30">
              <summary class="faq-summary flex items-center justify-between gap-4 px-5 py-4 cursor-pointer list-none select-none">
                <span class="font-heading font-semibold text-base text-ink pr-4">
                  {faq.q}
                </span>
                <span class="faq-chevron flex-shrink-0 w-8 h-8 rounded-full bg-blue/8 border border-blue/15 flex items-center justify-center transition-all duration-300 group-open:bg-blue group-open:border-blue group-open:rotate-180">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-blue transition-colors duration-300 group-open:text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                  </svg>
                </span>
              </summary>
              <div class="faq-content px-5 pb-5 -mt-1">
                <div class="h-px w-full bg-border/60 mb-4"></div>
                <p class="font-body text-sm text-muted leading-relaxed max-w-2xl">
                  {faq.a}
                </p>
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}

    <!-- Bottom prompt: more questions? -->
    <div class="mt-12 text-center" data-reveal>
      <p class="font-body text-sm text-muted">
        Punya pertanyaan lain yang belum terjawab?
        <a href="https://wa.me/" class="text-blue font-semibold hover:underline ml-1" data-wa-location="faq_bottom">
          Tanya langsung via WhatsApp →
        </a>
      </p>
    </div>
  </div>
</section>

<style>
  /* Smooth slide reveal on accordion open via interpolate-size (modern browsers) */
  @supports (interpolate-size: allow-keywords) {
    .faq-item {
      interpolate-size: allow-keywords;
    }
    .faq-item .faq-content {
      overflow: hidden;
      transition: opacity 250ms ease;
    }
  }

  /* Fallback fade-in for older browsers */
  .faq-item .faq-content {
    animation: faqFadeIn 280ms ease-out;
  }
  .faq-item:not([open]) .faq-content {
    animation: none;
  }
  @keyframes faqFadeIn {
    from {
      opacity: 0;
      transform: translateY(-4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Subtle hover lift on closed items */
  .faq-item:not([open]):hover {
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 4px 12px rgba(15, 23, 42, 0.06);
    transform: translateY(-1px);
  }

  /* Open state: solid blue accent on chevron + slightly lifted card */
  .faq-item[open] {
    box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04), 0 6px 18px rgba(30, 115, 255, 0.08);
    border-color: rgba(30, 115, 255, 0.25);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item,
    .faq-chevron,
    .faq-item .faq-content {
      transition: none !important;
      animation: none !important;
    }
  }
</style>

<script>
  // Update FAQ bottom WA link to actual WhatsApp URL with prefilled message
  // (kept in inline script so site config isn't bundled to client unnecessarily)
  document.addEventListener('DOMContentLoaded', () => {
    const link = document.querySelector('[data-wa-location="faq_bottom"]') as HTMLAnchorElement | null;
    if (link && !link.href.includes('wa.me/0') && !link.href.includes('wa.me/6')) {
      // Find existing WA link on page and copy base URL
      const sample = document.querySelector('[data-wa-location="hero_cta"]') as HTMLAnchorElement | null;
      if (sample) {
        const url = new URL(sample.href);
        url.searchParams.set('text', 'Halo Kalsara, saya punya pertanyaan tentang layanan Anda yang belum terjawab di FAQ.');
        link.href = url.toString();
        link.target = '_blank';
        link.rel = 'noopener noreferrer';
      }
    }
  });
</script>
