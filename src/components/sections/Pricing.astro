---
import SectionLabel from '../ui/SectionLabel.astro';
import WhatsAppButton from '../WhatsAppButton.astro';
import { site } from '../../config/site';

const plans = [
  {
    id:       'foundation',
    name:     'Foundation',
    priceLabel: 'Mulai dari',
    priceValue: 'Rp3.500.000',
    scope:    'Company Profile & Landing Page',
    items:    [
      'Tampilan website yang mencerminkan brand Anda — bukan template generik',
      'Tampilan rapi di HP & tablet — 80%+ pelanggan Anda dari HP',
      'Bisnis Anda bisa ditemukan di Google — struktur SEO dioptimalkan',
      'Kami bantu urus domain & hosting — Anda tidak perlu pusing teknis',
      '1 bulan pendampingan setelah website live',
    ],
    timeline: '⏱ Estimasi 7–14 hari kerja',
    featured: false,
    cta:      'Pilih Paket Ini',
    // Sprout / seedling icon — start small
    iconPath: 'M12 2.25a.75.75 0 0 1 .75.75v6.546l3.22-3.22a.75.75 0 1 1 1.06 1.06l-4.5 4.5a.75.75 0 0 1-1.06 0l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.22 3.22V3a.75.75 0 0 1 .75-.75ZM3 14.25a.75.75 0 0 1 .75.75v3a1.5 1.5 0 0 0 1.5 1.5h13.5a1.5 1.5 0 0 0 1.5-1.5v-3a.75.75 0 0 1 1.5 0v3a3 3 0 0 1-3 3H5.25a3 3 0 0 1-3-3v-3a.75.75 0 0 1 .75-.75Z',
  },
  {
    id:       'growth',
    name:     'Growth',
    priceLabel: 'Mulai dari',
    priceValue: 'Rp7.500.000',
    scope:    'E-Commerce & Website Multi-page',
    items:    [
      'Semua dari paket Foundation',
      'Katalog produk + dashboard pesanan',
      'Pembayaran online + transfer bank',
      'Kelola produk & konten sendiri',
      '3 bulan support teknis + 1 sesi panduan',
    ],
    timeline: '⏱ Estimasi 14–21 hari kerja',
    featured: true,
    cta:      'Diskusikan Paket Ini',
    // Trending up / chart icon — growth
    iconPath: 'M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941',
  },
  {
    id:       'custom',
    name:     'Custom Solution',
    priceLabel: 'Mulai dari',
    priceValue: 'Rp15.000.000',
    scope:    'Custom Solution',
    items:    [
      'Sistem yang dirancang khusus untuk proses bisnis Anda',
      'Contoh: sistem booking klinik — portal pendaftaran sekolah — dashboard penjualan',
      'Terhubung dengan tools yang sudah Anda pakai (WA, email, POS)',
      'Analisis kebutuhan & rekomendasi sistem — sebelum development dimulai',
      'Maintenance plan bulanan tersedia (opsional)',
    ],
    timeline: '⏱ Estimasi 30–60 hari kerja (tergantung kompleksitas)',
    featured: false,
    cta:      'Jadwalkan Konsultasi',
    // Cube / 3D box icon — custom build
    iconPath: 'M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9',
  },
] as const;
---

<section class="bg-surface py-20 md:py-28 px-6 relative overflow-hidden" id="harga">
  <!-- Soft top accent line -->
  <div class="pricing__bg-fade" aria-hidden="true"></div>

  <div class="max-w-site mx-auto relative">
    <div class="mb-12" data-reveal>
      <SectionLabel class="mb-3">Paket Harga</SectionLabel>
      <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-ink">
        Investasi yang Sesuai dengan Tahap Bisnis Anda.
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-start">
      {plans.map((p, i) => (
        <div
          data-plan={p.id}
          data-reveal
          data-reveal-delay={(i * 100).toString()}
          class={[
            'pricing-card group rounded-2xl p-8 flex flex-col relative transition-all duration-300',
            p.featured
              ? 'pricing-card--featured text-white border-2 border-blue shadow-card-featured md:-translate-y-3'
              : 'bg-white text-ink border border-border shadow-card hover:shadow-card-hover hover:-translate-y-2 hover:border-blue/40',
          ].join(' ')}
        >
          {p.featured && (
            <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 z-10">
              <span class="pricing-badge inline-flex items-center gap-1.5 bg-gradient-to-r from-blue to-cyan text-white text-xs font-body font-semibold px-4 py-1.5 rounded-full whitespace-nowrap shadow-[0_4px_14px_rgba(30,115,255,0.45)]">
                <span class="relative flex h-1.5 w-1.5">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-white/60 opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-white"></span>
                </span>
                Paling Dipilih
              </span>
            </div>
          )}

          <!-- Plan icon -->
          <div class={[
            'pricing-card__icon w-12 h-12 rounded-xl flex items-center justify-center mb-5 transition-transform duration-300 group-hover:scale-110 group-hover:-rotate-6',
            p.featured
              ? 'bg-gradient-to-br from-cyan/25 to-blue/25 ring-1 ring-cyan/40'
              : 'bg-gradient-to-br from-blue/10 to-cyan/10 ring-1 ring-blue/15 group-hover:ring-blue/30',
          ].join(' ')}>
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke={p.featured ? '#5EEAFF' : '#1E73FF'} class="w-6 h-6">
              <path stroke-linecap="round" stroke-linejoin="round" d={p.iconPath} />
            </svg>
          </div>

          <div class="mb-6">
            <div class={`flex items-center gap-2 mb-3 ${p.featured ? 'text-cyan' : 'text-blue'}`}>
              <span class={`block w-6 h-px ${p.featured ? 'bg-cyan/60' : 'bg-blue/50'}`}></span>
              <p class="font-body font-semibold text-xs tracking-[0.22em] uppercase">
                {p.name}
              </p>
            </div>
            <p class={`font-body text-xs uppercase tracking-wider mb-1 ${p.featured ? 'text-white/40' : 'text-muted/60'}`}>
              {p.priceLabel}
            </p>
            <p class={`font-heading font-extrabold text-2xl md:text-3xl leading-tight mb-2 ${p.featured ? 'text-white' : 'text-ink'}`}>
              {p.priceValue}
            </p>
            <p class={`font-body text-sm ${p.featured ? 'text-white/50' : 'text-muted'}`}>{p.scope}</p>
          </div>

          <!-- Divider -->
          <div class={`h-px w-full mb-6 ${p.featured ? 'bg-white/10' : 'bg-border'}`}></div>

          <ul class={`space-y-3 mb-8 flex-1 ${p.featured ? 'text-white/75' : 'text-muted'}`}>
            {p.items.map((item) => (
              <li class="flex items-start gap-2.5 font-body text-sm">
                <span class={[
                  'shrink-0 inline-flex items-center justify-center w-5 h-5 rounded-full mt-0.5',
                  p.featured ? 'bg-cyan/20' : 'bg-blue/10',
                ].join(' ')}>
                  <svg xmlns="http://www.w3.org/2000/svg" class={`w-3 h-3 ${p.featured ? 'text-cyan' : 'text-blue'}`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                  </svg>
                </span>
                <span class="leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>

          <p class="font-body text-xs text-muted/60 mb-6">{p.timeline}</p>

          <WhatsAppButton
            href={site.waUrl(`Halo Kalsara, saya tertarik dengan ${p.name}. Boleh saya konsultasi?`)}
            location={`pricing_${p.id}`}
            class={[
              'pricing-cta inline-flex items-center justify-center gap-2 text-center py-3 px-6 rounded-full font-body font-semibold text-sm transition-all duration-200 will-change-transform',
              p.featured
                ? 'bg-blue text-white shadow-[0_4px_14px_rgba(30,115,255,0.4)] hover:bg-blue/90 hover:shadow-[0_8px_22px_rgba(30,115,255,0.55)] hover:-translate-y-0.5'
                : 'border border-border text-ink hover:border-blue hover:text-blue hover:bg-blue/5 hover:-translate-y-0.5',
            ].join(' ')}
          >
            {p.cta}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-200 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
            </svg>
          </WhatsAppButton>
        </div>
      ))}
    </div>

    <p class="mt-10 text-center font-body text-xs text-muted/70">
      <span class="font-semibold text-ink/60">Tidak termasuk di semua paket:</span>
      Copywriting · Fotografi produk · Biaya domain & hosting tahunan · Maintenance setelah support berakhir (tersedia terpisah)
    </p>

    <p class="mt-5 text-center font-body text-sm text-muted">
      Setiap proyek memiliki kebutuhan yang berbeda. Hubungi kami untuk mendapatkan estimasi yang sesuai.
      <br class="hidden sm:block" />
      <span class="text-ink/70">Konsultasi 30 menit gratis, tanpa komitmen.</span>
    </p>
  </div>
</section>

<style>
  /* Featured card: deep navy radial gradient + subtle shimmer */
  .pricing-card--featured {
    background:
      radial-gradient(120% 80% at 50% 0%, rgba(30, 115, 255, 0.18), transparent 55%),
      radial-gradient(80% 60% at 100% 100%, rgba(0, 212, 255, 0.10), transparent 55%),
      #001F54;
    position: relative;
    isolation: isolate;
  }
  .pricing-card--featured::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: radial-gradient(120% 60% at 50% 0%, rgba(255, 255, 255, 0.06), transparent 55%);
    opacity: 0;
    transition: opacity 400ms ease;
    pointer-events: none;
    z-index: -1;
  }
  .pricing-card--featured:hover::before {
    opacity: 1;
  }

  /* Soft section top fade */
  .pricing__bg-fade {
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(30, 115, 255, 0.25), transparent);
    pointer-events: none;
  }
</style>
