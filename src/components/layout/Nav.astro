---
import { site } from '../../config/site';
import Button from '../ui/Button.astro';
---

<header class="fixed top-0 left-0 right-0 z-50 transition-all duration-200" id="navbar">
  <nav class="max-w-site mx-auto px-6 flex items-center justify-between h-16">
    <!-- Logo -->
    <a href="/" class="flex-shrink-0 transition-opacity hover:opacity-80">
      <img src="/kalsara_logo.png" alt="Kalsara Studio" class="h-7 w-auto block brightness-0 invert" width="200" height="59" loading="eager" decoding="async" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-8" role="list">
      {site.nav.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-body text-sm text-white/70 hover:text-white transition-colors"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop CTA -->
    <div class="hidden md:block">
      <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer">
        Konsultasi
      </Button>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="md:hidden flex flex-col gap-1.5 p-2 text-white"
      aria-label="Buka menu navigasi"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-0.5 bg-white transition-all" id="bar1"></span>
      <span class="block w-6 h-0.5 bg-white transition-all" id="bar2"></span>
      <span class="block w-4 h-0.5 bg-white transition-all" id="bar3"></span>
    </button>
  </nav>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="md:hidden hidden bg-ink px-6 pb-6 pt-2 border-t border-white/10"
    role="menu"
  >
    <ul class="flex flex-col gap-4 mb-6" role="list">
      {site.nav.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class="font-body text-base text-white/80 hover:text-white transition-colors"
            role="menuitem"
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
    <Button href={site.waUrl()} target="_blank" rel="noopener noreferrer" class="w-full justify-center">
      Konsultasi Gratis
    </Button>
  </div>
</header>

<!-- Offset for fixed nav -->
<div class="h-16"></div>

<script>
  const navbar   = document.getElementById('navbar')!;
  const toggle   = document.getElementById('nav-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;

  // Scroll: add bg to navbar
  window.addEventListener('scroll', () => {
    if (window.scrollY > 10) {
      navbar.classList.add('bg-navy/95', 'backdrop-blur-sm', 'border-b', 'border-white/10');
    } else {
      navbar.classList.remove('bg-navy/95', 'backdrop-blur-sm', 'border-b', 'border-white/10');
    }
  }, { passive: true });

  // Mobile menu toggle
  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden') === false;
    toggle.setAttribute('aria-expanded', String(isOpen));
    toggle.setAttribute('aria-label', isOpen ? 'Tutup menu navigasi' : 'Buka menu navigasi');
  });

  // Close menu when a link is clicked
  menu.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      toggle.setAttribute('aria-expanded', 'false');
    });
  });
</script>
