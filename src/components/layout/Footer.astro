---
import { site } from '../../config/site';
import WhatsAppButton from '../WhatsAppButton.astro';
---

<footer class="bg-ink text-white">
  <div class="max-w-site mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">

      <!-- Column 1: Brand -->
      <div class="lg:col-span-1">
        <a href="/" class="inline-block mb-4 transition-opacity hover:opacity-80">
          <img src="/kalsara_logo.png" alt="Kalsara Studio" class="h-7 w-auto block brightness-0 invert" width="200" height="59" loading="lazy" decoding="async" />
        </a>
        <p class="font-body text-sm text-white/50 leading-relaxed">
          Website dan solusi digital untuk membantu bisnis berkembang.
        </p>
      </div>

      <!-- Column 2: Services -->
      <div>
        <h4 class="font-heading font-bold text-sm text-white mb-4 uppercase tracking-widest">Layanan</h4>
        <ul class="space-y-3">
          <li><a href="#layanan" class="font-body text-sm text-white/50 hover:text-white transition-colors">Website Company Profile</a></li>
          <li><a href="#layanan" class="font-body text-sm text-white/50 hover:text-white transition-colors">Landing Page</a></li>
          <li><a href="#layanan" class="font-body text-sm text-white/50 hover:text-white transition-colors">E-Commerce</a></li>
          <li><a href="#layanan" class="font-body text-sm text-white/50 hover:text-white transition-colors">Custom Web App</a></li>
        </ul>
      </div>

      <!-- Column 3: Navigation -->
      <div>
        <h4 class="font-heading font-bold text-sm text-white mb-4 uppercase tracking-widest">Navigasi</h4>
        <ul class="space-y-3">
          <li><a href="#tentang" class="font-body text-sm text-white/50 hover:text-white transition-colors">Tentang</a></li>
          <li><a href="#layanan" class="font-body text-sm text-white/50 hover:text-white transition-colors">Layanan</a></li>
          <li><a href="#harga" class="font-body text-sm text-white/50 hover:text-white transition-colors">Harga</a></li>
          <li><a href="#faq" class="font-body text-sm text-white/50 hover:text-white transition-colors">FAQ</a></li>
        </ul>
      </div>

      <!-- Column 4: Contact -->
      <div>
        <h4 class="font-heading font-bold text-sm text-white mb-4 uppercase tracking-widest">Kontak</h4>
        <ul class="space-y-3">
          <li>
            <a href="mailto:hello@kalsara.id" class="inline-flex items-center gap-2 font-body text-sm text-white/50 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              hello@kalsara.id
            </a>
          </li>
          <li>
            <WhatsAppButton href={site.waUrl()} location="footer_contact" class="inline-flex items-center gap-2 font-body text-sm text-white/50 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              WhatsApp
            </WhatsAppButton>
          </li>
          <li>
            <a href="https://instagram.com/kalsaradigital" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 font-body text-sm text-white/50 hover:text-white transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              Instagram
            </a>
          </li>
          <li>
            <span class="inline-flex items-center gap-2 font-body text-sm text-white/50">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
              </svg>
              Tangerang Selatan, Indonesia
            </span>
          </li>
        </ul>
      </div>

    </div>

    <div class="pt-6 border-t border-white/10 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
      <p class="font-body text-xs text-white/30">
        &copy; {new Date().getFullYear()} Kalsara Digital Studio. All rights reserved.
      </p>
      <ul class="flex flex-wrap gap-x-5 gap-y-2">
        <li>
          <a href="/kebijakan-privasi" class="font-body text-xs text-white/40 hover:text-white/80 transition-colors">
            Kebijakan Privasi
          </a>
        </li>
        <li>
          <a href="/syarat-ketentuan" class="font-body text-xs text-white/40 hover:text-white/80 transition-colors">
            Syarat &amp; Ketentuan
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>
