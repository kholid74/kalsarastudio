---
import { site } from '../../config/site';
import WhatsAppButton from '../WhatsAppButton.astro';

const year = new Date().getFullYear();

// Service links — point to anchors that exist
const services = [
  { label: 'Website Company Profile', href: '#layanan' },
  { label: 'Landing Page',             href: '#layanan' },
  { label: 'E-Commerce',               href: '#layanan' },
  { label: 'Custom Web App',           href: '#layanan' },
  { label: 'Website Sekolah',          href: '#layanan' },
] as const;

const nav = [
  { label: 'Layanan',    href: '#layanan' },
  { label: 'Karya',      href: '#karya' },
  { label: 'Harga',      href: '#harga' },
  { label: 'Proses',     href: '#proses' },
  { label: 'FAQ',        href: '#faq' },
] as const;
---

<footer class="footer relative bg-ink text-white overflow-hidden">
  <!-- Top accent line -->
  <div class="footer__top-accent" aria-hidden="true"></div>

  <!-- Decorative background pattern -->
  <div class="footer__bg-pattern" aria-hidden="true"></div>
  <div class="footer__bg-glow" aria-hidden="true"></div>

  <!-- CTA Strip — primary closing CTA (since FinalCTA section is hidden to avoid duplication) -->
  <div class="relative max-w-site mx-auto px-6 pt-16 md:pt-20">
    <div class="footer-cta relative bg-gradient-to-br from-blue/15 via-white/[0.03] to-cyan/10 border border-white/12 rounded-2xl p-10 md:p-12 lg:p-14 overflow-hidden">
      <div class="footer-cta__glow" aria-hidden="true"></div>
      <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-10 items-center">
        <div class="lg:col-span-7">
          <p class="font-body text-xs sm:text-sm font-semibold tracking-[0.22em] uppercase text-cyan/80 mb-4">
            <span class="inline-block w-1.5 h-1.5 rounded-full bg-cyan align-middle mr-2"></span>
            Siap diskusi proyek?
          </p>
          <h2 class="font-heading font-extrabold text-3xl sm:text-4xl md:text-5xl text-white leading-[1.1] tracking-tight mb-4">
            Ceritakan apa yang ingin Anda bangun.
          </h2>
          <p class="font-body text-base md:text-lg text-white/65 leading-relaxed max-w-xl">
            Tidak perlu tahu istilah teknisnya. Ceritakan kebutuhan bisnis Anda — kami bantu definisikan scope, timeline, dan estimasi investasi. Gratis, tanpa komitmen.
          </p>
        </div>

        <div class="lg:col-span-5 flex flex-col gap-3 lg:items-end">
          <div class="flex flex-col sm:flex-row lg:flex-col xl:flex-row gap-3 w-full lg:w-auto">
            <WhatsAppButton
              href={site.waUrl()}
              location="footer_cta"
              class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-white text-ink rounded-full font-body font-semibold text-base shadow-[0_4px_14px_rgba(255,255,255,0.2)] hover:shadow-[0_6px_22px_rgba(255,255,255,0.32)] hover:-translate-y-0.5 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
              </svg>
              Konsultasi via WhatsApp
            </WhatsAppButton>

            <a
              href="mailto:hello@kalsara.id?subject=Diskusi%20Proyek%20Website"
              class="inline-flex items-center justify-center gap-2 px-7 py-4 bg-white/[0.06] border border-white/15 text-white rounded-full font-body font-semibold text-base backdrop-blur-sm hover:bg-white/[0.1] hover:border-white/25 transition-all"
            >
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
              </svg>
              Email Kami
            </a>
          </div>
          <p class="font-body text-xs text-white/40 mt-1 lg:text-right">
            Respon dalam 1 hari kerja · Senin–Jumat 09.00–18.00 WIB
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- Main footer grid -->
  <div class="relative max-w-site mx-auto px-6 pt-14 md:pt-16 pb-10">
    <div class="grid grid-cols-2 lg:grid-cols-12 gap-x-8 gap-y-10 mb-10">

      <!-- Brand column (wider on lg+) -->
      <div class="col-span-2 lg:col-span-4">
        <a href="/" class="inline-block mb-5 transition-opacity hover:opacity-80">
          <img
            src="/kalsara_logo.png"
            alt="Kalsara Studio"
            class="h-7 w-auto block brightness-0 invert"
            width="200"
            height="59"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="font-body text-sm text-white/55 leading-relaxed mb-6 max-w-xs">
          Studio digital boutique yang membantu bisnis lokal Indonesia membangun fondasi digital yang tumbuh sesuai kebutuhan.
        </p>

        <!-- Social icons row -->
        <div class="flex items-center gap-2">
          <a
            href="https://instagram.com/kalsaradigital"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram Kalsara"
            class="footer-social w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <WhatsAppButton
            href={site.waUrl()}
            location="footer_social"
            aria-label="WhatsApp Kalsara"
            class="footer-social w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
          </WhatsAppButton>
          <a
            href="mailto:hello@kalsara.id"
            aria-label="Email Kalsara"
            class="footer-social w-10 h-10 rounded-full bg-white/5 border border-white/10 flex items-center justify-center text-white/60 hover:text-white hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all"
          >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Services column -->
      <div class="col-span-1 lg:col-span-3">
        <h4 class="font-heading font-bold text-xs text-white mb-5 uppercase tracking-[0.18em]">
          <span class="inline-block w-1 h-1 rounded-full bg-cyan align-middle mr-2"></span>
          Layanan
        </h4>
        <ul class="space-y-3">
          {services.map((s) => (
            <li>
              <a href={s.href} class="footer-link font-body text-sm text-white/50 hover:text-white transition-colors inline-flex items-center group">
                <span class="inline-block w-0 group-hover:w-2 h-px bg-cyan transition-all duration-200 mr-0 group-hover:mr-2"></span>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Navigation column -->
      <div class="col-span-1 lg:col-span-2">
        <h4 class="font-heading font-bold text-xs text-white mb-5 uppercase tracking-[0.18em]">
          <span class="inline-block w-1 h-1 rounded-full bg-cyan align-middle mr-2"></span>
          Navigasi
        </h4>
        <ul class="space-y-3">
          {nav.map((n) => (
            <li>
              <a href={n.href} class="footer-link font-body text-sm text-white/50 hover:text-white transition-colors inline-flex items-center group">
                <span class="inline-block w-0 group-hover:w-2 h-px bg-cyan transition-all duration-200 mr-0 group-hover:mr-2"></span>
                {n.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact column -->
      <div class="col-span-2 lg:col-span-3">
        <h4 class="font-heading font-bold text-xs text-white mb-5 uppercase tracking-[0.18em]">
          <span class="inline-block w-1 h-1 rounded-full bg-cyan align-middle mr-2"></span>
          Kontak Langsung
        </h4>
        <ul class="space-y-4">
          <!-- Email -->
          <li>
            <a href="mailto:hello@kalsara.id" class="group inline-flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:bg-blue/15 group-hover:border-blue/30 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-white/70 group-hover:text-cyan transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
                </svg>
              </span>
              <div>
                <p class="font-body text-[10px] uppercase tracking-wider text-white/35 mb-0.5">Email</p>
                <p class="font-body text-sm text-white/70 group-hover:text-white transition-colors">hello@kalsara.id</p>
              </div>
            </a>
          </li>

          <!-- WhatsApp -->
          <li>
            <WhatsAppButton
              href={site.waUrl()}
              location="footer_contact"
              class="group inline-flex items-start gap-3"
            >
              <span class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:bg-green-500/15 group-hover:border-green-500/30 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-white/70 group-hover:text-green-400 transition-colors" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                  <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.554 4.118 1.528 5.849L.057 23.5l5.818-1.528A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.88 0-3.644-.49-5.17-1.348l-.371-.218-3.85 1.011 1.03-3.763-.242-.386A9.967 9.967 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
                </svg>
              </span>
              <div>
                <p class="font-body text-[10px] uppercase tracking-wider text-white/35 mb-0.5">WhatsApp</p>
                <p class="font-body text-sm text-white/70 group-hover:text-white transition-colors">Chat langsung</p>
              </div>
            </WhatsAppButton>
          </li>

          <!-- Location + hours -->
          <li>
            <div class="inline-flex items-start gap-3">
              <span class="w-8 h-8 rounded-lg bg-white/5 border border-white/10 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
                </svg>
              </span>
              <div>
                <p class="font-body text-[10px] uppercase tracking-wider text-white/35 mb-0.5">Lokasi & Jam</p>
                <p class="font-body text-sm text-white/70">Tangerang Selatan, ID</p>
                <p class="font-body text-xs text-white/45 mt-0.5">Senin–Jumat · 09.00–18.00 WIB</p>
              </div>
            </div>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-white/8 flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <p class="font-body text-xs text-white/35">
          &copy; {year} <span class="text-white/55 font-medium">Kalsara Digital Studio</span>. All rights reserved.
        </p>
      </div>
      <ul class="flex flex-wrap gap-x-5 gap-y-2">
        <li>
          <a href="/kebijakan-privasi" class="font-body text-xs text-white/45 hover:text-white/80 transition-colors">
            Kebijakan Privasi
          </a>
        </li>
        <li>
          <a href="/syarat-ketentuan" class="font-body text-xs text-white/45 hover:text-white/80 transition-colors">
            Syarat &amp; Ketentuan
          </a>
        </li>
        <li>
          <a href="/sitemap-index.xml" class="font-body text-xs text-white/45 hover:text-white/80 transition-colors">
            Sitemap
          </a>
        </li>
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background:
      radial-gradient(ellipse 60% 50% at 50% 0%, rgba(30, 115, 255, 0.06), transparent 70%),
      linear-gradient(180deg, #0A1428 0%, #050B1A 100%);
  }

  /* Top accent line — fades in from sides */
  .footer__top-accent {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.4), rgba(30, 115, 255, 0.4), transparent);
  }

  /* Subtle dot pattern */
  .footer__bg-pattern {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle at 1px 1px, rgba(255, 255, 255, 0.04) 1px, transparent 0);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 80% 100% at 50% 50%, black 40%, transparent 90%);
    -webkit-mask-image: radial-gradient(ellipse 80% 100% at 50% 50%, black 40%, transparent 90%);
    pointer-events: none;
  }

  /* Soft glow at center */
  .footer__bg-glow {
    position: absolute;
    width: 600px;
    height: 300px;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    background: radial-gradient(ellipse, rgba(30, 115, 255, 0.08), transparent 70%);
    filter: blur(60px);
    pointer-events: none;
  }

  /* CTA panel inner glow */
  .footer-cta__glow {
    position: absolute;
    width: 400px;
    height: 200px;
    top: -50px;
    right: -100px;
    background: radial-gradient(ellipse, rgba(0, 212, 255, 0.15), transparent 60%);
    filter: blur(50px);
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-social,
    .footer-link span,
    .animate-pulse {
      transition: none !important;
      animation: none !important;
    }
  }
</style>
