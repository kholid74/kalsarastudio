---
import { site } from '../../config/site';
---

<footer class="bg-ink text-white">
  <div class="max-w-site mx-auto px-6 py-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
      <!-- Brand -->
      <div>
        <p class="font-heading font-bold text-lg tracking-widest text-cyan uppercase mb-1">Kalsara</p>
        <p class="font-body text-sm text-white/50">{site.tagline}</p>
      </div>

      <!-- Nav links -->
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-6" role="list">
          {site.nav.map(({ label, href }) => (
            <li>
              <a href={href} class="font-body text-sm text-white/50 hover:text-white transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>

    <div class="mt-10 pt-6 border-t border-white/10 flex flex-col sm:flex-row justify-between gap-2">
      <p class="font-body text-xs text-white/30">
        &copy; {new Date().getFullYear()} {site.name}. All rights reserved.
      </p>
      <p class="font-body text-xs text-white/30">
        Dibangun dengan standar engineering yang kuat.
      </p>
    </div>
  </div>
</footer>
