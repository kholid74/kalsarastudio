---
import '@fontsource/plus-jakarta-sans/700.css';
import '@fontsource/plus-jakarta-sans/800.css';
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '../styles/global.css';
import { site } from '../config/site';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title       = site.name,
  description = site.description,
  ogImage     = site.ogImage,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, site.url).toString();

const organizationLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${site.url}#organization`,
  name: site.name,
  url: site.url,
  logo: new URL('/kalsara_logo.png', site.url).toString(),
  description: site.description,
  email: site.email,
  telephone: `+${site.whatsapp}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Tangerang Selatan',
    addressRegion: 'Banten',
    addressCountry: 'ID',
  },
  founder: {
    '@type': 'Person',
    '@id': `${site.url}#founder`,
    name: 'Kholid Putra',
    jobTitle: 'Founder & Lead Engineer',
    worksFor: { '@id': `${site.url}#organization` },
  },
  areaServed: { '@type': 'Country', name: 'Indonesia' },
  knowsAbout: [
    'Web Development',
    'Software Engineering',
    'Custom Web Application',
    'E-Commerce',
    'Landing Page',
    'Company Profile Website',
  ],
  sameAs: ['https://instagram.com/kalsaradigital'],
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${site.url}#service`,
  name: site.name,
  provider: { '@id': `${site.url}#organization` },
  areaServed: { '@type': 'Country', name: 'Indonesia' },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Layanan Kalsara Digital Studio',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Website Company Profile' },
        price: '3500000',
        priceCurrency: 'IDR',
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Landing Page' },
        price: '3500000',
        priceCurrency: 'IDR',
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'E-Commerce Website' },
        price: '7500000',
        priceCurrency: 'IDR',
      },
      {
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: 'Custom Web Application' },
        price: '15000000',
        priceCurrency: 'IDR',
      },
    ],
  },
};

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Apakah domain dan hosting sudah termasuk dalam harga?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Biaya domain dan hosting tidak termasuk dalam paket harga kami. Kami akan memberikan rekomendasi penyedia hosting yang sesuai dengan kebutuhan dan anggaran Anda, serta membantu proses setup-nya.',
      },
    },
    {
      '@type': 'Question',
      name: 'Berapa lama proses pengerjaan website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Tergantung pada kompleksitas proyek. Company profile dan landing page biasanya selesai dalam 2–3 minggu. E-commerce 3–5 minggu. Custom web application didiskusikan berdasarkan scope pekerjaan.',
      },
    },
    {
      '@type': 'Question',
      name: 'Berapa kali revisi yang diperbolehkan?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Setiap paket mencakup revisi yang disepakati di awal dalam proposal. Revisi di luar scope dapat diakomodasi dengan biaya tambahan yang transparan sebelum dikerjakan.',
      },
    },
    {
      '@type': 'Question',
      name: 'Siapa yang memiliki source code dan konten website?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Anda. Setelah pelunasan, seluruh source code, aset, dan konten website menjadi hak milik Anda sepenuhnya. Tidak ada biaya lisensi atau ketergantungan pada platform kami.',
      },
    },
    {
      '@type': 'Question',
      name: 'Apakah ada layanan maintenance setelah website diluncurkan?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ya. Setiap paket mencakup periode support setelah launch. Kami juga menyediakan paket maintenance bulanan untuk update konten, keamanan, dan performa.',
      },
    },
    {
      '@type': 'Question',
      name: 'Apakah website yang dibangun bisa dikembangkan menjadi aplikasi lebih besar?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ya. Website kami dibangun di atas arsitektur yang dapat berkembang. Ketika bisnis Anda siap, kami dapat membangun dashboard, CRM, sistem internal, atau aplikasi custom di atas fondasi yang sudah ada.',
      },
    },
  ],
};

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [organizationLd, serviceLd, faqLd],
};
---

<!DOCTYPE html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalUrl} />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={new URL(ogImage, site.url).toString()} />
    <meta property="og:locale"      content="id_ID" />

    <!-- Twitter -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={new URL(ogImage, site.url).toString()} />

    <!-- JSON-LD -->
    <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />

    <link rel="icon" type="image/png" href="/kalsara_favicon.png" />
    <link rel="apple-touch-icon" href="/kalsara_favicon.png" />

    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-1LV02DQFWD" is:inline></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-1LV02DQFWD');
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { trackWhatsAppClick } from '../lib/analytics';
      document.addEventListener('click', (e) => {
        const el = (e.target as Element).closest('[data-wa-location]') as HTMLElement | null;
        if (!el) return;
        trackWhatsAppClick(el.dataset.waLocation ?? 'unknown');
      });
    </script>
  </body>
</html>
