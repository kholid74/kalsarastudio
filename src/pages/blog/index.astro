---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/layout/Nav.astro';
import Footer from '../../components/layout/Footer.astro';
import { getCollection } from 'astro:content';
import { site } from '../../config/site';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Base title={`Blog — ${site.name}`} description="Artikel dan insight seputar website, digitalisasi bisnis, dan custom web application.">
  <Nav />
  <main class="bg-white min-h-screen py-24 px-6">
    <div class="max-w-site mx-auto">
      <h1 class="font-heading font-extrabold text-4xl text-ink mb-12">Blog</h1>

      {posts.length === 0 && (
        <p class="font-body text-muted">Belum ada artikel. Coming soon.</p>
      )}

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {posts.map((post) => (
          <a href={`/blog/${post.slug}`} class="group block border border-border rounded-xl p-6 hover:border-blue transition-colors">
            <p class="font-body text-xs text-muted mb-2">
              {post.data.publishDate.toLocaleDateString('id-ID', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            <h2 class="font-heading font-bold text-lg text-ink mb-2 group-hover:text-blue transition-colors">
              {post.data.title}
            </h2>
            <p class="font-body text-sm text-muted">{post.data.description}</p>
          </a>
        ))}
      </div>
    </div>
  </main>
  <Footer />
</Base>
