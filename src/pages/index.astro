---
import Base from '../layouts/Base.astro';
import Nav from '../components/layout/Nav.astro';
import Footer from '../components/layout/Footer.astro';
import FloatingWhatsApp from '../components/FloatingWhatsApp.astro';
import Hero from '../components/sections/Hero.astro';
import TrustedBy from '../components/sections/TrustedBy.astro';
// import Founder from '../components/sections/Founder.astro'; // hidden — pending copy review
import Experience from '../components/sections/Experience.astro';
import Services from '../components/sections/Services.astro';
import WhyKalsara from '../components/sections/WhyKalsara.astro';
import IdealClient from '../components/sections/IdealClient.astro';
import Process from '../components/sections/Process.astro';
import Pricing from '../components/sections/Pricing.astro';
import FAQ from '../components/sections/FAQ.astro';
// import FinalCTA from '../components/sections/FinalCTA.astro'; // hidden — superseded by Footer CTA strip to avoid CTA duplication
---

<Base>
  <Nav />
  <main>
    <Hero />
    <TrustedBy />
    <Services />
    <Experience />
    <IdealClient />
    <WhyKalsara />
    <Pricing />
    <Process />
    {/* <Founder /> — hidden until copy is reviewed */}
    <FAQ />
    {/* <FinalCTA /> — hidden: footer CTA strip (Mari diskusikan kebutuhan...) now serves as the closing CTA */}
  </main>
  <Footer />
  <FloatingWhatsApp />
</Base>
