---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/layout/Nav.astro';
import Footer from '../../components/layout/Footer.astro';
import FloatingWhatsApp from '../../components/FloatingWhatsApp.astro';
import WhatsAppButton from '../../components/WhatsAppButton.astro';
import { site } from '../../config/site';
import { projects, type Project } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props as { project: Project };

const statusClass = {
  'Client Project': 'text-blue bg-blue/8 border-blue/15',
  'Showcase Concept': 'text-amber-700 bg-amber-50 border-amber-200',
  'Coming Soon': 'text-muted bg-gray-50 border-border',
};

const title = `${project.title} — Portfolio Kalsara Digital Studio`;
const description = project.summary;
const waHref = site.waUrl(`Halo Kalsara, saya tertarik membuat website seperti ${project.title}. Bisa diskusi?`);
---

<Base title={title} description={description}>
  <Nav />
  <main class="bg-surface">
    <!-- Case Study Hero -->
    <section class="relative overflow-hidden bg-navy text-white pt-32 pb-16 md:pt-40 md:pb-24 px-6">
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,rgba(30,115,255,0.18),transparent_38%),linear-gradient(180deg,rgba(0,212,255,0.06),transparent_45%)]" aria-hidden="true"></div>
      <div class="relative max-w-site mx-auto">
        <a href="/#karya" class="inline-flex items-center gap-2 font-body text-sm text-white/55 hover:text-white transition-colors mb-8">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" />
          </svg>
          Kembali ke Karya
        </a>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-12 items-center">
          <div class="lg:col-span-6">
            <div class="flex flex-wrap items-center gap-2 mb-5">
              <span class:list={[
                'font-body text-xs font-semibold uppercase tracking-wider border rounded-full px-3 py-1',
                statusClass[project.status],
              ]}>
                {project.status}
              </span>
              <span class="font-body text-xs font-semibold uppercase tracking-wider text-cyan bg-cyan/10 border border-cyan/20 rounded-full px-3 py-1">
                {project.category}
              </span>
            </div>

            <h1 class="font-heading font-extrabold text-4xl md:text-6xl leading-[1.05] tracking-tight mb-5">
              {project.title}
            </h1>
            <p class="font-body text-lg md:text-xl text-white/65 leading-relaxed max-w-2xl mb-8">
              {project.summary}
            </p>

            <div class="flex flex-col sm:flex-row gap-3">
              <a
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 bg-white text-ink px-6 py-3 rounded-full font-body font-semibold text-sm hover:bg-white/90 transition-colors"
              >
                Buka Website
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 7.5h9m0 0v9m0-9-9 9" />
                </svg>
              </a>
              <WhatsAppButton
                href={waHref}
                location={`case_study_${project.slug}`}
                class="inline-flex items-center justify-center gap-2 border border-white/20 bg-white/5 text-white px-6 py-3 rounded-full font-body font-semibold text-sm hover:bg-white/10 transition-colors"
              >
                Diskusi Website Serupa
              </WhatsAppButton>
            </div>
          </div>

          <div class="lg:col-span-6">
            <div class="rounded-2xl overflow-hidden border border-white/12 bg-white/5 shadow-[0_24px_80px_rgba(0,0,0,0.35)]">
              <div class="bg-white/8 px-4 py-3 flex items-center gap-2 border-b border-white/10">
                <span class="w-3 h-3 rounded-full bg-red-400"></span>
                <span class="w-3 h-3 rounded-full bg-yellow-400"></span>
                <span class="w-3 h-3 rounded-full bg-green-400"></span>
                <div class="ml-2 flex-1 rounded-full bg-white/10 px-3 py-1">
                  <p class="font-body text-xs text-white/45 truncate">{project.url.replace('https://', '')}</p>
                </div>
              </div>
              <div class="aspect-[16/10] bg-white/5 overflow-hidden">
                <Image
                  src={project.image}
                  alt={project.imageAlt}
                  width={960}
                  height={600}
                  format="webp"
                  quality={86}
                  class="w-full h-full object-cover object-top"
                  loading="eager"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Overview -->
    <section class="py-16 md:py-20 px-6">
      <div class="max-w-site mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-4">
          <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-blue mb-3">Project Overview</p>
          <h2 class="font-heading font-extrabold text-3xl text-ink leading-tight">Ringkasan project</h2>
        </div>
        <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-4">
          {[
            ['Industri', project.industry],
            ['Tipe Website', project.type],
            ['Status', project.status],
            ['Fokus Utama', project.tags.join(' · ')],
          ].map(([label, value]) => (
            <div class="bg-white border border-border rounded-xl p-5 shadow-card">
              <p class="font-body text-xs uppercase tracking-wider text-muted/60 mb-1">{label}</p>
              <p class="font-body font-semibold text-ink">{value}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Challenge / Solution -->
    <section class="pb-16 md:pb-20 px-6">
      <div class="max-w-site mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
        <article class="bg-white border border-border rounded-2xl p-7 md:p-8 shadow-card">
          <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-muted mb-4">Challenge</p>
          <h2 class="font-heading font-extrabold text-2xl text-ink mb-4">Masalah yang ingin dijawab</h2>
          <p class="font-body text-base text-muted leading-relaxed">{project.challenge}</p>
        </article>
        <article class="bg-ink text-white border border-ink rounded-2xl p-7 md:p-8 shadow-card">
          <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-cyan mb-4">Solution</p>
          <h2 class="font-heading font-extrabold text-2xl mb-4">Pendekatan solusi</h2>
          <p class="font-body text-base text-white/65 leading-relaxed">{project.solution}</p>
        </article>
      </div>
    </section>

    <!-- Features / Decisions -->
    <section class="pb-16 md:pb-20 px-6">
      <div class="max-w-site mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8">
        <div class="lg:col-span-5">
          <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-blue mb-3">Key Features</p>
          <h2 class="font-heading font-extrabold text-3xl text-ink leading-tight mb-5">Fitur yang mendukung kebutuhan bisnis</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-1 gap-3">
            {project.features.map((feature) => (
              <div class="flex items-center gap-3 bg-white border border-border rounded-xl px-4 py-3 shadow-card">
                <span class="w-6 h-6 rounded-full bg-blue/10 text-blue flex items-center justify-center shrink-0">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                  </svg>
                </span>
                <span class="font-body text-sm font-medium text-ink">{feature}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="lg:col-span-7">
          <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-blue mb-3">UX / Conversion Decisions</p>
          <h2 class="font-heading font-extrabold text-3xl text-ink leading-tight mb-5">Keputusan yang dibuat bukan hanya untuk tampilan</h2>
          <div class="space-y-4">
            {project.decisions.map((decision, index) => (
              <article class="bg-white border border-border rounded-xl p-5 shadow-card">
                <div class="flex gap-4">
                  <span class="font-heading font-extrabold text-lg text-blue/40 shrink-0">{String(index + 1).padStart(2, '0')}</span>
                  <p class="font-body text-base text-muted leading-relaxed">{decision}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    {project.sectionBreakdown && project.sectionBreakdown.length > 0 && (
      <section class="pb-16 md:pb-20 px-6">
        <div class="max-w-site mx-auto">
          <div class="mb-8">
            <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-blue mb-3">Section Breakdown</p>
            <h2 class="font-heading font-extrabold text-3xl text-ink leading-tight max-w-2xl">
              Bagaimana halaman ini disusun untuk mendukung konversi
            </h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
            {project.sectionBreakdown.map((section, index) => (
              <article class="bg-white border border-border rounded-2xl p-6 shadow-card hover:shadow-card-hover hover:-translate-y-0.5 transition-all">
                <div class="w-10 h-10 rounded-full bg-blue/10 text-blue flex items-center justify-center font-heading font-extrabold text-sm mb-5">
                  {index + 1}
                </div>
                <h3 class="font-heading font-bold text-lg text-ink mb-3">{section.title}</h3>
                <p class="font-body text-sm text-muted leading-relaxed mb-4">{section.description}</p>
                <div class="border-t border-border pt-4">
                  <p class="font-body text-xs font-semibold uppercase tracking-wider text-muted/60 mb-1">Tujuan</p>
                  <p class="font-body text-sm font-medium text-ink leading-relaxed">{section.purpose}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {(project.expectedImpact?.length || project.seoOpportunities?.length) && (
      <section class="pb-16 md:pb-20 px-6">
        <div class="max-w-site mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6">
          {project.expectedImpact && project.expectedImpact.length > 0 && (
            <article class="lg:col-span-7 bg-ink text-white border border-ink rounded-2xl p-7 md:p-8 shadow-card">
              <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-cyan mb-4">Expected Impact</p>
              <h2 class="font-heading font-extrabold text-2xl md:text-3xl leading-tight mb-6">
                Dampak yang dirancang untuk dicapai
              </h2>
              <div class="space-y-4">
                {project.expectedImpact.map((impact) => (
                  <div class="flex gap-3">
                    <span class="w-6 h-6 rounded-full bg-cyan/15 text-cyan flex items-center justify-center shrink-0 mt-0.5">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.704 4.153a.75.75 0 0 1 .143 1.052l-8 10.5a.75.75 0 0 1-1.127.075l-4.5-4.5a.75.75 0 0 1 1.06-1.06l3.894 3.893 7.48-9.817a.75.75 0 0 1 1.05-.143Z" clip-rule="evenodd" />
                      </svg>
                    </span>
                    <p class="font-body text-base text-white/70 leading-relaxed">{impact}</p>
                  </div>
                ))}
              </div>
            </article>
          )}

          {project.seoOpportunities && project.seoOpportunities.length > 0 && (
            <article class="lg:col-span-5 bg-white border border-border rounded-2xl p-7 md:p-8 shadow-card">
              <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-blue mb-4">SEO Opportunity</p>
              <h2 class="font-heading font-extrabold text-2xl text-ink mb-5">
                Keyword yang bisa ditargetkan
              </h2>
              <div class="flex flex-wrap gap-2">
                {project.seoOpportunities.map((keyword) => (
                  <span class="font-body text-sm font-medium text-ink bg-surface border border-border rounded-full px-3 py-1.5">
                    {keyword}
                  </span>
                ))}
              </div>
              <p class="font-body text-sm text-muted leading-relaxed mt-5">
                Catatan: ini adalah peluang SEO berbasis tipe website dan niche, bukan klaim ranking.
              </p>
            </article>
          )}
        </div>
      </section>
    )}

    <!-- Ideal For + CTA -->
    <section class="pb-20 md:pb-28 px-6">
      <div class="max-w-site mx-auto bg-white border border-border rounded-2xl p-7 md:p-10 shadow-card">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-7">
            <p class="font-body text-xs font-semibold tracking-[0.22em] uppercase text-blue mb-3">Ideal untuk</p>
            <h2 class="font-heading font-extrabold text-3xl text-ink mb-5">Website serupa cocok untuk bisnis seperti ini</h2>
            <div class="flex flex-wrap gap-2">
              {project.idealFor.map((item) => (
                <span class="font-body text-sm font-medium text-ink bg-surface border border-border rounded-full px-3 py-1.5">
                  {item}
                </span>
              ))}
            </div>
          </div>
          <div class="lg:col-span-5 lg:text-right">
            <p class="font-body text-base text-muted leading-relaxed mb-5 lg:ml-auto max-w-md">
              Ingin website dengan struktur dan alur konversi seperti ini untuk bisnis Anda?
            </p>
            <WhatsAppButton
              href={waHref}
              location={`case_study_bottom_${project.slug}`}
              class="inline-flex items-center justify-center gap-2 bg-blue text-white px-7 py-4 rounded-full font-body font-semibold text-base shadow-[0_4px_14px_rgba(30,115,255,0.35)] hover:shadow-[0_6px_20px_rgba(30,115,255,0.45)] hover:-translate-y-0.5 transition-all"
            >
              Diskusikan Website Serupa
            </WhatsAppButton>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <FloatingWhatsApp />
</Base>
